# ── Vercel (production / preview / development) ─────────────────────────────
LIBSQL_URL=https://krypton-db.chessonchain.online
NEXT_PUBLIC_DYNAMIC_ENV_ID=
NEXT_PUBLIC_KRYPTON_PROGRAM_ID=DQVp9hnnU6zbyPCJbcEnS6F1fWZMQ2yCCH9jL6cFVPxF

# RPC priority: Helius (primary) → Alchemy (fallback) → public cluster URL
NEXT_PUBLIC_SOLANA_RPC_URL=https://devnet.helius-rpc.com/?api-key=YOUR_HELIUS_KEY
NEXT_PUBLIC_SOLANA_RPC_FALLBACK_URL=https://solana-devnet.g.alchemy.com/v2/YOUR_ALCHEMY_KEY
NEXT_PUBLIC_SOLANA_RPC_MAINNET_URL=https://mainnet.helius-rpc.com/?api-key=YOUR_HELIUS_KEY
NEXT_PUBLIC_SOLANA_RPC_MAINNET_FALLBACK_URL=https://solana-mainnet.g.alchemy.com/v2/YOUR_ALCHEMY_KEY

# Optional server-only overrides (API routes prefer these when set)
# SOLANA_RPC_URL=
# SOLANA_RPC_FALLBACK_URL=
# SOLANA_RPC_MAINNET_URL=
# SOLANA_RPC_MAINNET_FALLBACK_URL=

OPENROUTER_API_KEY=
OPENROUTER_POLICY_MODEL=openrouter/owl-alpha
KRYPTON_STUB_AGENTS=true

# Session encryption: base64-encoded 32-byte key for encrypting chat messages at rest.
# If unset, falls back to a deterministic derived key (NOT production-safe — set this).
# Generate with: node -e "console.log(Buffer.from(require('crypto').randomBytes(32)).toString('base64'))"
SESSION_ENCRYPTION_KEY=

# ── VPS orchestrator only (.env.orchestrator) ─────────────────────────────────
# LIBSQL_URL=http://127.0.0.1:8787
# KRYPTON_ORCHESTRATOR_POLL_MS=2000
