//#region src/modules/wallets/reconcileWalletAccountsAgainstClient/reconcileWalletAccountsAgainstClient.ts
/**
* Reconciles freshly-connected wallet accounts against the client state. For
* each candidate it classifies as new, a re-connect of an existing unverified
* account, or a re-connect of an already-verified account, then runs the
* appropriate state mutation (`setUnverifiedWalletAccounts`,
* `updateWalletProviderKeysForVerifiedCredentials`, `createVisit` for truly-new
* entries) and emits a single `walletAccountsChanged` event if anything
* actually changed. Returns the candidates with `verifiedCredentialId`
* populated when the address already corresponded to a verified credential.
*
* @not-instrumented
*/
const reconcileWalletAccountsAgainstClient = ({ addToDynamicWalletAccounts = true, walletAccounts, walletProviderKey }, client) => {
	if (walletAccounts.length === 0) return [];
	const existingWalletAccounts = getWalletAccounts(client);
	const newWalletAccounts = [];
	const unverifiedWalletAccountsToUpdate = [];
	const verifiedCredentialIdToWalletProviderKeyMap = {};
	const reconciledWalletAccounts = walletAccounts.map((candidate) => {
		const matchingExistingWalletAccount = existingWalletAccounts.find((existingWalletAccount) => existingWalletAccount.id === candidate.id);
		if (!matchingExistingWalletAccount) {
			newWalletAccounts.push(candidate);
			return candidate;
		}
		const isWalletProviderKeyChanged = matchingExistingWalletAccount.walletProviderKey !== walletProviderKey;
		if (matchingExistingWalletAccount.verifiedCredentialId) {
			if (isWalletProviderKeyChanged) verifiedCredentialIdToWalletProviderKeyMap[matchingExistingWalletAccount.verifiedCredentialId] = walletProviderKey;
			return {
				...candidate,
				verifiedCredentialId: matchingExistingWalletAccount.verifiedCredentialId
			};
		}
		if (isWalletProviderKeyChanged) unverifiedWalletAccountsToUpdate.push(candidate);
		return candidate;
	});
	let walletAccountsChanged = false;
	if (Object.keys(verifiedCredentialIdToWalletProviderKeyMap).length > 0) {
		updateWalletProviderKeysForVerifiedCredentials({ keysToUpdate: verifiedCredentialIdToWalletProviderKeyMap }, client);
		walletAccountsChanged = true;
	}
	if (addToDynamicWalletAccounts) {
		const accountsToWrite = [...unverifiedWalletAccountsToUpdate, ...newWalletAccounts];
		if (accountsToWrite.length > 0) {
			setUnverifiedWalletAccounts({ unverifiedWalletAccountsToUpdate: accountsToWrite }, client);
			walletAccountsChanged = true;
			for (const newWalletAccount of newWalletAccounts) createVisit({ walletAccount: newWalletAccount }, client);
		}
	}
	if (walletAccountsChanged) emitWalletAccountsChangedEvent(client);
	return reconciledWalletAccounts;
};

