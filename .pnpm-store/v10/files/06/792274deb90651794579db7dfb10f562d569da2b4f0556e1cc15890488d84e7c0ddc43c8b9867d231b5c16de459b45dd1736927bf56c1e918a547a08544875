	if (sBytes.length === 33 && sBytes[0] === 0) sBytes = sBytes.slice(1);
	const result = new Uint8Array(64);
	result.set(rBytes, 32 - rBytes.length);
	result.set(sBytes, 64 - sBytes.length);
	return result;
};

