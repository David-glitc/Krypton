'use client'
import { useMemo } from 'react';
import '../../../context/DynamicContext/useDynamicContext/useDynamicContext.js';
import { useInternalDynamicContext } from '../../../context/DynamicContext/useDynamicContext/useInternalDynamicContext/useInternalDynamicContext.js';
import { useInternalUserWallets } from '../../../context/UserWalletsContext/UserWalletsContext.js';
import { useWalletGroups } from '../../../store/state/walletOptions/walletOptions.js';
import { buildWalletsList } from './buildWalletsList.js';

const useWalletList = ({ isWalletConnectList = false, viewWalletsFilter, searchFilter, lastUsedWalletKey, }) => {
    const { walletsFilter, walletConnectorOptions, defaultNumberOfWalletsToShow, bridgeChainsToConnect, multiWallet, recommendedWallets, selectedTabSettings, } = useInternalDynamicContext();
    const { userWallets } = useInternalUserWallets();
    const walletGroups = useWalletGroups();
    // Run the heavy list build once per real input change, not on every render —
    // a modal close animation re-renders this hundreds of times.
    return useMemo(() => buildWalletsList({
        bridgeChainsToConnect,
        defaultNumberOfWalletsToShow,
        isWalletConnectList,
        lastUsedWalletKey,
        multiWallet,
        recommendedWallets,
        searchFilter,
        selectedTabSettings,
        userWallets,
        viewWalletsFilter,
        walletConnectorOptions,
        walletGroups,
        walletsFilter,
    }), [
        bridgeChainsToConnect,
        defaultNumberOfWalletsToShow,
        isWalletConnectList,
        lastUsedWalletKey,
        multiWallet,
        recommendedWallets,
        searchFilter,
        selectedTabSettings,
        userWallets,
        viewWalletsFilter,
        walletConnectorOptions,
        walletGroups,
        walletsFilter,
    ]);
};

export { useWalletList };
