/**
* Default auth-session opener — uses `react-native-inappbrowser-reborn`
* (ASWebAuthenticationSession on iOS, Chrome Custom Tabs on Android). Used
* when the host app has not overridden `coreConfig.openAuthSession`.
*/
const openDefaultAuthSession = async ({ authUrl, redirectUrl }) => {
	const { default: InAppBrowser } = await import("react-native-inappbrowser-reborn");
	try {
		InAppBrowser.closeAuth();
	} catch {}
	const result = await InAppBrowser.openAuth(authUrl, redirectUrl);
	if (result.type === "success" && result.url) return {
		type: "success",
		url: result.url
	};
	return { type: "cancel" };
};
/**
* Signs the user in with a social provider via an in-app authentication
* session, then completes the flow and returns the authenticated user.
*
* Requires `metadata.nativeLink` to be set on the client — it is used as
* the OAuth redirect URL; the provider redirects back to it after the user
* authenticates. The auth session defaults to `react-native-inappbrowser-reborn`;
* override via `coreConfig.openAuthSession` to plug in a different browser.
*
* Supports every provider in `SocialProvider` (Apple, Discord, Facebook,
* Github, Google, Kraken, LinkedIn, Microsoft, Epic Games, Steam, TikTok,
* Twitch, Twitter).
*
* @param params.provider - The social provider to authenticate with.
* @param [client] - The Dynamic client instance. Only required when using multiple Dynamic clients.
* @returns The authenticated user, or null if the verify response had none.
* @throws UserCancelledSocialPopUpError If the user dismisses the pop-up before completing auth.
* @throws InvalidSocialCallbackOriginError If the callback URL origin does not match `metadata.nativeLink`.
* @instrumented
*/
const signInWithSocialPopUp = async ({ provider }, client = getDefaultClient()) => {
	const core = getCore(client);
	const apiClient = createApiClient({}, client);
	const { appNativeLink } = getAppMetadata(client);
	assertDefined(appNativeLink, "metadata.nativeLink must be set on the Dynamic client to use signInWithSocialPopUp");
	await core.initTrack.waitForAll();
	const providerType = provider;
	const { url, state, codeVerifier } = await buildOAuthUrl(core, providerType);
	await apiClient.initAuth({
		environmentId: core.environmentId,
		oauthInitAuthRequest: {
			redirectUrl: appNativeLink,
			state
		},
		providerType
	});
	await core.storage.setItem(redirectStateStorageKeySchema, {
		codeVerifier,
		provider: providerType,
		state
	});
	const openSession = core.openAuthSession ?? openDefaultAuthSession;
	try {
		const result = await openSession({
			authUrl: url.toString(),
			redirectUrl: appNativeLink
		});
		if (result.type === "cancel") throw new UserCancelledSocialPopUpError();
		const callbackUrl = new URL(result.url);
		const expectedUrl = new URL(appNativeLink);
		const callbackOrigin = `${callbackUrl.protocol}//${callbackUrl.host}`;
		const expectedOrigin = `${expectedUrl.protocol}//${expectedUrl.host}`;
		if (callbackOrigin !== expectedOrigin) throw new InvalidSocialCallbackOriginError({
			actualOrigin: callbackOrigin,
			expectedOrigin
		});
		return await __processSocialCallback_wrapped({ url: callbackUrl }, client);
	} catch (error) {
		await core.storage.removeItem(redirectStateStorageKeySchema);
		throw error;
	}
};
