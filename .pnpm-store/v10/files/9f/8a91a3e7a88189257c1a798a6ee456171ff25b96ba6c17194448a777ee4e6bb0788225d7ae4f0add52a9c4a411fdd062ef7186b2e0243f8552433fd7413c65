	const walletSpriteId = walletEntry?.brand?.spriteId;
	const walletIconUrl = walletSpriteId ? getSpriteUrl({ spriteId: walletSpriteId }) : void 0;
	return {
		connectionOptions,
		iconUrl: displayOverride?.iconUrl ?? groupIconUrl ?? walletIconUrl ?? "",
		installationUrls,
		key: walletOptionKey,
		name: displayOverride?.name ?? group?.name ?? walletEntry?.name ?? walletOptionKey,
		primaryColor: group?.brand?.primaryColor ?? walletEntry?.brand?.primaryColor
