pes';\n\nexport type { CompleteSocialRedirectParams } from './completeSocialRedirect.types';\n\n/**\n * Completing an OAuth redirect is not supported on React Native. Use\n * `signInWithSocialPopUp` instead: it opens the in-app auth session,\n * processes the callback, and returns the authenticated user in one call —\n * there is no separate \"complete\" step on native.\n *\n * @throws MethodNotImplementedError Always on React Native.\n * @instrumented\n */\nexport const completeSocialRedirect = async (\n  // eslint-disable-next-line @typescript-eslint/no-unused-vars -- params required to match standard signature in check-platform-types; destructure pattern cannot be renamed\n  { url, requestedScopes }: CompleteSocialRedirectParams,\n  // eslint-disable-next-line @typescript-eslint/no-unused-vars -- client default required by check-dynamic-client-param-in-external-functions\n  client = getDefaultClient()\n): Promise<User | null> => {\n  throw new MethodNotImplementedError(\n    'completeSocialRedirect (not needed on React Native — signInWithSocialPopUp processes the callback inline)'\n  );\n};\n","import { getDefaultClient } from '../../../../../client/defaultClient';\nimport type { SocialProvider } from '../../social.types';\nimport { signInWithSocialRedirect } from '../signInWithSocialRedirect';\n\ntype AuthenticateWithSocialParams = {\n  provider: SocialProvider;\n  redirectUrl: string;\n};\n\n/**\n * @deprecated Renamed to {@link signInWithSocialRedirect}. This alias will be\n * removed in a future major version.\n *\n * @instrumented\n */\nexport const authenticateWithSocial = (\n  params: AuthenticateWithSocialParams,\n  client = getDefaultClient()\n) => signInWithSocialRedirect(params, client);\n","import type { TokenScope } from '@dynamic-labs/sdk-api-core';\n\nimport { getDefaultClient } from '../../../../../client/defaultClient';\nimport type { User } from '../../../../user/user.types';\nimport { completeSocialRedirect } from '../completeSocialRedirect';\n\ntype CompleteSocialAuthenticationParams = {\n  requestedScopes?: TokenScope[];\n  url: URL;\n};\n\n/**\n * @deprecated Renamed to {@link completeSocialRedirect}. This alias will be\n * removed in a future major version.\n *\n * @instrumented\n */\nexport const completeSocialAuthentication = (\n  params: CompleteSocialAuthenticationParams,\n  client = getDefaultClient()\n): Promise<User | null> => completeSocialRedirect(params, client);\n","import { getDefaultClient } from '../../../../../client/defaultClient';\nimport { detectSocialRedirectUrl } from '../detectSocialRedirectUrl';\n\ntype DetectOAuthRedirectParams = {\n  url: URL;\n};\n\n/**\n * @deprecated Renamed to {@link detectSocialRedirectUrl}. This alias will be\n * removed in a future major version.\n *\n * @not-instrumented\n */\nexport const detectOAuthRedirect = (\n  params: DetectOAuthRedirectParams,\n  client = getDefaultClient()\n): Promise<boolean> => detectSocialRedirectUrl(params, client);\n","import { getDefaultClient } from '../../../../client/defaultClient';\nimport { getWalletAccounts } from '../../getWalletAccounts';\nimport type { WalletAccount } from '../../walletAccount';\n\n/**\n * Get the primary wallet account.\n * The primary wallet account is the one that was last selected by the user.\n * This information is stored in both unverified and verified wallet accounts.\n * This function consolidates this information to determine which wallet was most recently selected.\n  * @not-instrumented\n */\nexport const getPrimaryWalletAccount = (\n  client = getDefaultClient()\n): WalletAccount | null => {\n  const walletAccounts = getWalletAccounts(client);\n\n  const sortedLastSelectedWalletAccounts = walletAccounts\n    .filter(\n      (\n        walletAccount\n      ): walletAccount is WalletAccount & { lastSelectedAt: Date } =>\n        Boolean(walletAccount.lastSelectedAt)\n    )\n    .sort((a, b) => b.lastSelectedAt.getTime() - a.lastSelectedAt.getTime());\n\n  if (sortedLastSelectedWalletAccounts.length === 0) {\n    return null;\n  }\n\n  const [primaryWalletAccount] = sortedLastSelectedWalletAccounts;\n\n  return primaryWalletAccount;\n};\n","import type { VerifyResponse } from '@dynamic-labs/sdk-api-core';\n\nimport { getCore } from '../../../../../client/core/getCore';\nimport { getDefaultClient } from '../../../../../client/defaultClient';\nimport { createApiClient } from '../../../../apiClient';\nimport { getPrimaryWalletAccount } from '../../../../wallets/primaryWalletAccount/getPrimaryWalletAccount';\nimport { updateAuthFromVerifyResponse } from '../../../updateAuthFromVerifyResponse';\n\ntype UnlinkSocialAccountParams = {\n  verifiedCredentialId: string;\n};\n\n/**\n * Unlinks a social account from the user's account.\n *\n * @param params.verifiedCredentialId - The verified credential ID of the social account to unlink.\n * @param [client] - The Dynamic client instance. Only required when using multiple Dynamic clients.\n * @returns A promise that resolves to the verify response.\n * @instrumented\n * @redact-params\n */\nexport const unlinkSocialAccount = async (\n  { verifiedCredentialId }: UnlinkSocialAccountParams,\n  client = getDefaultClient()\n): Promise<VerifyResponse> => {\n  const core = getCore(client);\n  const apiClient = createApiClient({}, client);\n\n  // the api seems to require us to pass the primary wallet id when\n  // unlinking a social account if the user has wallets\n  const primaryWalletAccount = getPrimaryWalletAccount(client);\n  const walletId = primaryWalletAccount?.verifiedCredentialId?.replace(\n    '-zerodev',\n    ''\n  );\n\n  const response = await apiClient.verifyUnlink({\n    environmentId: core.environmentId,\n    verifyUnlinkRequest: {\n      verifiedCredentialId,\n      walletId: walletId ?? undefined,\n    },\n  });\n\n  updateAuthFromVerifyResponse({ response }, client);\n\n  return response;\n};\n","import type { ChainEnum, TokenBalance } from '@dynamic-labs/sdk-api-core';\n\nimport { getCore } from '../../../client/core/getCore';\nimport { getDefaultClient } from '../../../client/defaultClient';\nimport { createApiClient } from '../../apiClient';\nimport { getWalletProviderFromWalletAccount } from '../../wallets/utils/getWalletProviderFromWalletAccount';\nimport type { WalletAccount } from '../../wallets/walletAccount';\n\ntype GetTokenBalancesBaseParams = {\n  /**\n   * Whether to filter out spam tokens.\n   * Defaults to true.\n   * @not-instrumented\n   */\n  filterSpamTokens?: boolean;\n  /** Whether to force a refresh of the balances instead of using the api cached value. */\n  forceRefresh?: boolean;\n  /** Whether to include the native token balance. */\n  includeNative?: boolean;\n  /** Whether to include the prices of the tokens. */\n  includePrices?: boolean;\n  /** The wallet account to get the balances for. */\n  walletAccount: WalletAccount;\n  /** If provided, only return balances for the specified contracts. */\n  whitelistedContracts?: Array<string>;\n};\n\nexport type GetTokenBalancesParams = GetTokenBalancesBaseParams &\n  (\n    | {\n        /**\n         * The network ID to get the balances for.\n         * If neither `networkId` nor `networkIds` is provided, the active network ID will be used.\n         * Mutually exclusive with `networkIds`.\n         */\n        networkId?: number;\n        networkIds?: never;\n      }\n    | {\n        networkId?: never;\n        /**\n         * The network IDs to get the balances for.\n         * Mutually exclusive with `networkId`.\n         */\n        networkIds?: string[];\n      }\n  );\n\n/**\n * Retrieves the token balances for a wallet account on one chain. Fetched\n * from the Dynamic API.\n *\n * Use this for ERC-20-style token balances scoped to a single wallet\n * account. Supports optional spam filtering, price inclusion, native-token\n * inclusion, and one-or-many networks within the wallet's chain.\n *\n * For native-only balance, use {@link getNativeBalance}. For a\n * multi-chain portfolio across many addresses, use\n * {@link getMultichainTokenBalances}.\n *\n * @param params.walletAccount - The wallet account to get the balances for.\n * @param [client] - The Dynamic client instance. Only required when using multiple Dynamic clients.\n * @returns A promise that resolves to an array of token balances.\n * @not-instrumented\n */\nexport const getTokenBalances = async (\n  {\n    walletAccount,\n    networkId,\n    networkIds,\n    includePrices,\n    includeNative,\n    filterSpamTokens,\n    whitelistedContracts,\n    forceRefresh,\n  }: GetTokenBalancesParams,\n  client = getDefaultClient()\n): Promise<TokenBalance[]> => {\n  const core = getCore(client);\n  const apiClient = createApiClient({}, client);\n\n  if (!networkId && !networkIds) {\n    const walletProvider = getWalletProviderFromWalletAccount(\n      {\n        walletAccount,\n      },\n      client\n    );\n    const activeNetworkId = await walletProvider.getActiveNetworkId();\n    networkId = Number(activeNetworkId.networkId);\n  }\n\n  const balances = await apiClient.getAccountBalances({\n    accountAddress: walletAccount.address,\n    // eslint-disable-next-line custom-rules/ban-chain-enum\n    chainName: walletAccount.chain as ChainEnum,\n    environmentId: core.environmentId,\n    filterSpamTokens,\n    forceRefresh,\n    includeNative,\n    includePrices,\n    networkId,\n    networkIds,\n    whitelistedContracts,\n  });\n\n  return balances;\n};\n","import type {\n  MultichainAccountBalanceResponse,\n  MultichainAccountBalancesRequest,\n  MultichainAccountBalancesRequestBalanceRequests,\n} from '@dynamic-labs/sdk-api-core';\n\nimport { getCore } from '../../../client/core/getCore';\nimport { getDefaultClient } from '../../../client/defaultClient';\nimport { createApiClient } from '../../apiClient';\nimport type { Chain } from '../../chain/chain.types';\n\nexport type GetMultichainTokenBalancesBalanceRequest =\n  Omit<MultichainAccountBalancesRequest, 'balanceRequests'> & {\n    balanceRequests: Array<\n      Omit<MultichainAccountBalancesRequestBalanceRequests, 'chain'> & {\n        chain: Chain;\n      }\n    >;\n  };\n\nexport type GetMultichainTokenBalancesParams = {\n  balanceRequest: GetMultichainTokenBalancesBalanceRequest;\n};\n\n/**\n * Retrieves token balances across multiple chains, networks, and addresses\n * in a single batched API request.\n *\n * Use this for portfolio-style views that need to render a user's holdings\n * across their entire multi-chain wallet set. For a single account on one\n * chain, use {@link getTokenBalances}; for native-only balance, use\n * {@link getNativeBalance}.\n *\n * @param params.balanceRequest - The balance request configuration specifying which chains, networks and addresses to query.\n * @param [client] - The Dynamic client instance. Only required when using multiple Dynamic clients.\n * @returns A promise that resolves to the chain balances across multiple networks.\n * @not-instrumented\n */\nexport const getMultichainTokenBalances = async (\n  { balanceRequest }: GetMultichainTokenBalancesParams,\n  client = getDefaultClient()\n): Promise<MultichainAccountBalanceResponse['chainBalances']> => {\n  const core = getCore(client);\n  const apiClient = createApiClient({}, client);\n\n  const response = await apiClient.postMultichainAccountBalances({\n    environmentId: core.environmentId,\n    multichainAccountBalancesRequest:\n      balanceRequest as MultichainAccountBalancesRequest,\n  });\n\n  return response.chainBalances;\n};\n","import * as z from 'zod/mini';\n\nimport { createStorageKeySchema } from '../../../../services/storage';\n\n/** @not-instrumented */\n// eslint-disable-next-line custom-rules/require-single-object-param\nexport const createCheckoutSessionTokenStorageKey = (transactionId: string) => {\n  return createStorageKeySchema({\n    key: `checkoutSessionToken:${transactionId}`,\n    schema: z.string(),\n  });\n};\n","import type { SDKApi } from '@dynamic-labs/sdk-api-core';\n\nimport { getCore } from '../../../../client/core/getCore';\nimport type { DynamicClient } from '../../../../client/types';\nimport { CheckoutSessionTokenMissingError } from '../../../../errors/CheckoutSessionTokenMissingError';\nimport { createApiClient } from '../../../apiClient';\nimport { createCheckoutSessionTokenStorageKey } from '../createCheckoutSessionTokenStorageKey';\n\ntype CreateCheckoutApiClientParams = {\n  transactionId: string;\n};\n\ntype CheckoutApiClientResult = {\n  apiClient: SDKApi;\n  environmentId: string;\n  sessionToken: string;\n};\n\n/** @not-instrumented */\nexport const createCheckoutApiClient = async (\n  { transactionId }: CreateCheckoutApiClientParams,\n  client: DynamicClient\n): Promise<CheckoutApiClientResult> => {\n  const core = getCore(client);\n  const apiClient = createApiClient({}, client);\n\n  const sessionToken = await core.storage.getItem(\n    createCheckoutSessionTokenStorageKey(transactionId)\n  );\n\n  if (!sessionToken) {\n    throw new CheckoutSessionTokenMissingError({ transactionId });\n  }\n\n  return {\n    apiClient,\n    environmentId: core.environmentId,\n    sessionToken,\n  };\n};\n","import { getCore } from '../../../../client/core/getCore';\nimport type { DynamicClient } from '../../../../client/types';\nimport { createCheckoutSessionTokenStorageKey } from '../createCheckoutSessionTokenStorageKey';\n\nexport type ClearCheckoutSessionTokenParams = {\n  transactionId: string;\n};\n\n/**\n * Removes the locally stored checkout session token for the given transaction.\n *\n * The checkout session token is the anonymous credential that authorizes\n * mutations to a single in-flight checkout transaction. Once the transaction\n * has reached a terminal state (cancelled, expired, failed, completed) it can\n * no longer be advanced, and the token is dead weight that should not be\n * persisted in browser storage — leaving it around lets a later XSS payload\n * exfiltrate a credential with no further use, and it can also confuse the\n * SDK on subsequent loads into believing an active session exists.\n *\n * The server-side revocation lives in dashboard-api; this is the SDK-side\n * defense-in-depth.\n *\n * @not-instrumented\n */\nexport const clearCheckoutSessionToken = async (\n  { transactionId }: ClearCheckoutSessionTokenParams,\n  client: DynamicClient\n): Promise<void> => {\n  const core = getCore(client);\n\n  await core.storage.removeItem(\n    createCheckoutSessionTokenStorageKey(transactionId)\n  );\n};\n","import { getCore } from '../../../../client/core/getCore';\nimport { APIError } from '../../../../errors/APIError';\nimport type { DynamicClient } from '../../../../client/types';\nimport { clearCheckoutSessionToken } from '../clearCheckoutSessionToken';\n\nexport type WithCheckoutSessionTokenCleanupOn401Params<T> = {\n  call: () => Promise<T>;\n  transactionId: string;\n};\n\n/**\n * Checkout mutation routes are guarded server-side only by session-token\n * validation, so a 401 means the token is dead (revoked, expired, deleted,\n * or invalid). Leaving a dead token in `localStorage` widens the XSS\n * exfiltration surface for no benefit and makes the next SDK load attempt\n * requests that are guaranteed to fail.\n *\n * @not-instrumented\n */\nexport const withCheckoutSessionTokenCleanupOn401 = async <T>(\n  { call, transactionId }: WithCheckoutSessionTokenCleanupOn401Params<T>,\n  client: DynamicClient\n): Promise<T> => {\n  try {\n    return await call();\n  } catch (error) {\n    if (error instanceof APIError && error.status === 401) {\n      try {\n        await clearCheckoutSessionToken({ transactionId }, client);\n      } catch (cleanupError) {\n        getCore(client).logger.error(\n          'Failed to clear checkout session token after 401',\n          cleanupError\n        );\n      }\n    }\n    throw error;\n  }\n};\n","import type {\n  AttachSourceRequest,\n  ChainEnum,\n  CheckoutSourceTypeEnum,\n  ExchangeKeyEnum,\n} from '@dynamic-labs/sdk-api-core';\n\nimport { getDefaultClient } from '../../../client/defaultClient';\nimport type { Chain } from '../../chain';\nimport type {\n  CheckoutSupportedExchangeProvider,\n  CheckoutTransaction,\n} from '../checkout.types';\nimport { createCheckoutApiClient } from '../utils/createCheckoutApiClient';\nimport { withCheckoutSessionTokenCleanupOn401 } from '../utils/withCheckoutSessionTokenCleanupOn401';\n\ntype AttachCheckoutTransactionSourceWalletParams = {\n  /** The address of the user's wallet. */\n  fromAddress: string;\n  /** The network id for the token that the user is paying with. */\n  fromChainId: string;\n  /** The chain name of the user's wallet. */\n  fromChainName: Chain;\n  /** @defaultValue `'wallet'` */\n  sourceType?: 'wallet';\n  transactionId: string;\n};\n\ntype AttachCheckoutTransactionSourceExchangeParams = {\n  /**\n   * The exchange provider key (e.g. `'coinbase'`).\n   * The backend uses this to look up the exchange configuration,\n   * generate a buy URL, and create the exchange source record.\n   */\n  exchangeProvider: CheckoutSupportedExchangeProvider;\n  sourceType: 'exchange';\n  transactionId: string;\n};\n\n/**\n * Parameters for {@link attachCheckoutTransactionSource}.\n *\n * This is a discriminated union on `sourceType`:\n * - `'wallet'` (default) — requires `fromAddress`, `fromChainId`, `fromChainName`\n * - `'exchange'` — requires `exchangeProvider`\n */\nexport type AttachCheckoutTransactionSourceParams =\n  | AttachCheckoutTransactionSourceWalletParams\n  | AttachCheckoutTransactionSourceExchangeParams;\n\n/**\n * Attaches a payment source to a checkout transaction.\n *\n * For exchange sources, the backend generates the buy URL and creates the\n * exchange source record. The response includes `exchangeSource.metadata.url`\n * which can be embedded in an iframe for the user to complete payment.\n *\n * @param params AttachCheckoutTransactionSourceParams - The source details to attach.\n * @param [client] - The Dynamic client instance. Only required when using multiple Dynamic clients.\n * @returns The updated checkout transaction (with exchangeSource if sourceType is 'exchange')\n * @instrumented\n */\nexport const attachCheckoutTransactionSource = async (\n  params: AttachCheckoutTransactionSourceParams,\n  client = getDefaultClient()\n): Promise<CheckoutTransaction> => {\n  const { transactionId, sourceType = 'wallet' } = params;\n\n  const { apiClient, environmentId, sessionToken } =\n    await createCheckoutApiClient({ transactionId }, client);\n\n  const attachSourceRequest: AttachSourceRequest = {\n    sourceType: sourceType as CheckoutSourceTypeEnum,\n  };\n\n  if (params.sourceType === 'exchange') {\n    attachSourceRequest.exchangeProvider =\n      params.exchangeProvider as ExchangeKeyEnum;\n  } else {\n    attachSourceRequest.fromAddress = params.fromAddress;\n    attachSourceRequest.fromChainId = params.fromChainId;\n    // eslint-disable-next-line custom-rules/ban-chain-enum\n    attachSourceRequest.fromChainName = params.fromChainName as ChainEnum;\n  }\n\n  return withCheckoutSessionTokenCleanupOn401(\n    {\n      call: () =>\n        apiClient.attachSource({\n          attachSourceRequest,\n          environmentId,\n          transactionId,\n          xDynamicCheckoutSessionToken: sessionToken,\n        }),\n      transactionId,\n    },\n    client\n  );\n};\n","import type { CheckoutTransaction } from '@dynamic-labs/sdk-api-core';\n\nimport { getDefaultClient } from '../../../client/defaultClient';\nimport type { DynamicClient } from '../../../client/types';\nimport { createCheckoutApiClient } from '../utils/createCheckoutApiClient';\nimport { withCheckoutSessionTokenCleanupOn401 } from '../utils/withCheckoutSessionTokenCleanupOn401';\n\nexport type BroadcastCheckoutTransactionParams = {\n  transactionId: string;\n  /**\n   * The on-chain transaction hash. Required for wallet sources, optional\n   * for exchange sources (the user may not have it).\n   */\n  txHash?: string;\n};\n\n/**\n * Records that a checkout transaction has been broadcasted.\n *\n * For wallet sources, pass the `txHash` from the on-chain transaction.\n * For exchange sources, `txHash` can be omitted — the user confirms\n * they completed the payment and the transaction moves to `broadcasted`.\n *\n * @param params BroadcastCheckoutTransactionParams - The transaction ID and optional tx hash.\n * @param [client] - The Dynamic client instance. Only required when using multiple Dynamic clients.\n * @returns The updated checkout transaction\n * @instrumented\n */\nexport const broadcastCheckoutTransaction = async (\n  { transactionId, txHash }: BroadcastCheckoutTransactionParams,\n  client: DynamicClient = getDefaultClient()\n): Promise<CheckoutTransaction> => {\n  const { apiClient, environmentId, sessionToken } =\n    await createCheckoutApiClient({ transactionId }, client);\n\n  return withCheckoutSessionTokenCleanupOn401(\n    {\n      call: () =>\n        apiClient.recordCheckoutBroadcast({\n          environmentId,\n          recordBroadcastRequest: { txHash },\n          transactionId,\n          xDynamicCheckoutSessionToken: sessionToken,\n        }),\n      transactionId,\n    },\n    client\n  );\n};\n","import { getDefaultClient } from '../../../client/defaultClient';\nimport type { CheckoutTransaction } from '../checkout.types';\nimport { clearCheckoutSessionToken } from '../utils/clearCheckoutSessionToken';\nimport { createCheckoutApiClient } from '../utils/createCheckoutApiClient';\nimport { withCheckoutSessionTokenCleanupOn401 } from '../utils/withCheckoutSessionTokenCleanupOn401';\n\nexport type CancelCheckoutTransactionParams = {\n  transactionId: string;\n};\n\n/**\n * Cancels a checkout transaction before it has been broadcasted\n *\n * @param params CancelCheckoutTransactionParams - The transaction to cancel.\n * @param [client] - The Dynamic client instance. Only required when using multiple Dynamic clients.\n * @returns The cancelled checkout transaction\n * @instrumented\n */\nexport const cancelCheckoutTransaction = async (\n  { transactionId }: CancelCheckoutTransactionParams,\n  client = getDefaultClient()\n): Promise<CheckoutTransaction> => {\n  const { apiClient, environmentId, sessionToken } =\n    await createCheckoutApiClient({ transactionId }, client);\n\n  const result = await withCheckoutSessionTokenCleanupOn401(\n    {\n      call: () =>\n        apiClient.cancelCheckoutTransaction({\n          environmentId,\n          transactionId,\n          xDynamicCheckoutSessionToken: sessionToken,\n        }),\n      transactionId,\n    },\n    client\n  );\n\n  await clearCheckoutSessionToken({ transactionId }, client);\n\n  return result;\n};\n","import type { Checkout } from '@dynamic-labs/sdk-api-core';\n\nimport type { DynamicClient } from '../../../client/types';\nimport { assertDefined } from '../../../utils/assertDefined';\n\n/** @not-instrumented */\nexport const getCheckouts = async (\n  client: DynamicClient\n): Promise<Checkout[]> => {\n  const projectSettings = client.projectSettings;\n\n  assertDefined(projectSettings, 'Project settings are not available');\n\n  return projectSettings.checkouts ?? [];\n};\n","import type { ChainEnum } from '@dynamic-labs/sdk-api-core';\n\nimport { getCore } from '../../../client/core/getCore';\nimport { getDefaultClient } from '../../../client/defaultClient';\nimport type { DynamicClient } from '../../../client/types';\nimport { assertDefined } from '../../../utils/assertDefined';\nimport { createApiClient } from '../../apiClient';\nimport type { Chain } from '../../chain';\nimport type { CheckoutTransactionCreateResponse } from '../checkout.types';\nimport { getCheckouts } from '../getCheckouts';\nimport { createCheckoutSessionTokenStorageKey } from '../utils/createCheckoutSessionTokenStorageKey';\n// TODO(realtime): Re-enable the realtime auto-subscribe once the Ably API key\n// is provisioned in the dashboard-api environment. The `realtime/auth`\n// endpoint currently returns \"Realtime service is not configured\" for\n// environments without Ably wiring, so we are temporarily disabling the\n// auto-subscribe to avoid surfacing connection errors to customers. See\n// https://dynamiclabsgroup.slack.com/archives/C03DWBF0LE8/p1778590548698209\n// import { subscribeToCheckoutTransaction } from '../utils/subscribeToCheckoutTransaction';\n\nexport type DestinationAddress = {\n  address: string;\n  chain: Chain;\n};\n\nexport type CreateCheckoutTransactionParams = {\n  amount: string;\n  checkoutId?: string;\n  currency: string;\n  /**\n   * The destination addresses for each settlement token destination.\n   * Must be provided for each settlement token chain, unless the\n   * addresses have already been provided on the checkout creation.\n   */\n  destinationAddresses?: DestinationAddress[];\n  expiresIn?: number;\n  memo?: object;\n};\n\n/**\n * Creates a new checkout transaction and stores the session token for subsequent calls\n *\n * @param params CreateCheckoutTransactionParams - The parameters for the checkout transaction.\n * @param [client] - The Dynamic client instance. Only required when using multiple Dynamic clients.\n * @returns The created transaction with session token\n * @instrumented\n */\nexport const createCheckoutTransaction = async (\n  params: CreateCheckoutTransactionParams,\n  client: DynamicClient = getDefaultClient()\n): Promise<CheckoutTransactionCreateResponse> => {\n  const core = getCore(client);\n  const apiClient = createApiClient({}, client);\n\n  const checkouts = await getCheckouts(client);\n\n  // If no checkout ID is provided, try to fallback to the first checkout in the list\n  const checkoutId = params.checkoutId || checkouts?.[0]?.id;\n\n  assertDefined(\n    checkoutId,\n    'No checkout found. Please make sure you have a Checkout setup in the Dashboard.'\n  );\n\n  const result = await apiClient.createCheckoutTransaction({\n    checkoutId,\n    checkoutTransactionCreateRequest: {\n      amount: params.amount,\n      currency: params.currency,\n      destinationAddresses: params.destinationAddresses?.map((address) => ({\n        address: address.address,\n        // eslint-disable-next-line custom-rules/ban-chain-enum\n        chainName: address.chain as ChainEnum,\n      })),\n      expiresIn: params.expiresIn,\n      memo: params.memo,\n    },\n    environmentId: core.environmentId,\n  });\n\n  await core.storage.setItem(\n    createCheckoutSessionTokenStorageKey(result.transaction.id),\n    result.sessionToken\n  );\n\n  // TODO(realtime): Re-enable the realtime auto-subscribe once the Ably API\n  // key is provisioned in the dashboard-api environment. See the import\n  // block above for context.\n  // subscribeToCheckoutTransaction(\n  //   { transactionId: result.transaction.id },\n  //   client\n  // ).catch((error) => {\n  //   core.logger.error(\n  //     'Failed to subscribe to checkout transaction realtime channel',\n  //     error\n  //   );\n  // });\n\n  return result;\n};\n","import { getCore } from '../../../client/core/getCore';\nimport { getDefaultClient } from '../../../client/defaultClient';\nimport type { DynamicClient } from '../../../client/types';\nimport { createApiClient } from '../../apiClient';\nimport type { CheckoutTransaction } from '../checkout.types';\n\nexport type GetCheckoutTransactionParams = {\n  transactionId: string;\n};\n\n/**\n * Fetches the current state of a checkout transaction\n *\n * @param params GetCheckoutTransactionParams - The parameters for fetching the transaction.\n * @param [client] - The Dynamic client instance. Only required when using multiple Dynamic clients.\n * @returns The checkout transaction\n  * @not-instrumented\n */\nexport const getCheckoutTransaction = async (\n  { transactionId }: GetCheckoutTransactionParams,\n  client: DynamicClient = getDefaultClient()\n): Promise<CheckoutTransaction> => {\n  const core = getCore(client);\n  const apiClient = createApiClient({}, client);\n\n  return apiClient.getCheckoutTransaction({\n    environmentId: core.environmentId,\n    transactionId,\n  });\n};\n","import { getDefaultClient } from '../../../client/defaultClient';\nimport type { CheckoutTransaction } from '../checkout.types';\nimport { createCheckoutApiClient } from '../utils/createCheckoutApiClient';\nimport { withCheckoutSessionTokenCleanupOn401 } from '../utils/withCheckoutSessionTokenCleanupOn401';\n\nexport type GetCheckoutTransactionQuoteParams = {\n  /**\n   * Optional chain identifier the source funds will originate from for this\n   * quote. When provided, this overrides the fromChainId recorded at\n   * attachSource time. The chain family (fromChainName) and source address\n   * (fromAddress) are locked at attachSource time — to switch chain families\n   * or wallets, call attachSource again.\n   */\n  fromChainId?: string;\n  /**\n   * When omitted, defaults to native token for the chain specified in\n   * fromChainName in the attach source step.\n   */\n  fromTokenAddress?: string;\n  slippage?: number;\n  transactionId: string;\n};\n\n/**\n * Fetches a quote for a checkout transaction\n *\n * @param params GetCheckoutTransactionQuoteParams - The quote parameters.\n * @param [client] - The Dynamic client instance. Only required when using multiple Dynamic clients.\n * @returns The updated checkout transaction with quote data\n * @not-instrumented\n */\nexport const getCheckoutTransactionQuote = async (\n  {\n    fromChainId,\n    fromTokenAddress,\n    slippage,\n    transactionId,\n  }: GetCheckoutTransactionQuoteParams,\n  client = getDefaultClient()\n): Promise<CheckoutTransaction> => {\n  const { apiClient, environmentId, sessionToken } =\n    await createCheckoutApiClient({ transactionId }, client);\n\n  return withCheckoutSessionTokenCleanupOn401(\n    {\n      call: () =>\n        apiClient.quoteCheckoutTransaction({\n          environmentId,\n          quoteRequest: {\n            fromChainId,\n            fromTokenAddress,\n            slippage,\n          },\n          transactionId,\n          xDynamicCheckoutSessionToken: sessionToken,\n        }),\n      transactionId,\n    },\n    client\n  );\n};\n","import { getDefaultClient } from '../../../client/defaultClient';\nimport type { CheckoutTransaction } from '../checkout.types';\nimport { createCheckoutApiClient } from '../utils/createCheckoutApiClient';\nimport { withCheckoutSessionTokenCleanupOn401 } from '../utils/withCheckoutSessionTokenCleanupOn401';\n\nexport type PrepareCheckoutTransactionParams = {\n  /**\n   * Whether to assert the balance for the gas cost of the transaction.\n   * If true, the prepare signing request will fail if the balance is not sufficient for the gas cost.\n   * @default false\n   */\n  assertBalanceForGasCost?: boolean;\n  /**\n   * Whether to assert the balance for the transfer amount of the transaction.\n   * If true, the prepare signing request will fail if the balance is not sufficient for the transfer amount.\n   * @default false\n   */\n  assertBalanceForTransferAmount?: boolean;\n  transactionId: string;\n};\n\n/**\n * Prepares a checkout transaction for signing\n * This should be called immediately before triggering the transaction signing.\n * It will confirm the quote is still valid, the risk state is cleared, and the transaction is ready to be signed.\n *\n * @param params PrepareCheckoutTransactionParams - The transaction to prepare.\n * @param [client] - The Dynamic client instance. Only required when using multiple Dynamic clients.\n * @returns The updated checkout transaction\n * @instrumented\n */\nexport const prepareCheckoutTransaction = async (\n  {\n    assertBalanceForGasCost,\n    assertBalanceForTransferAmount,\n    transactionId,\n  }: PrepareCheckoutTransactionParams,\n  client = getDefaultClient()\n): Promise<CheckoutTransaction> => {\n  const { apiClient, environmentId, sessionToken } =\n    await createCheckoutApiClient({ transactionId }, client);\n\n  return withCheckoutSessionTokenCleanupOn401(\n    {\n      call: () =>\n        apiClient.prepareCheckoutTransaction({\n          environmentId,\n          prepareSigningRequest: {\n            assertBalanceForGasCost: assertBalanceForGasCost ?? false,\n            assertBalanceForTransferAmount:\n              assertBalanceForTransferAmount ?? false,\n          },\n          transactionId,\n          xDynamicCheckoutSessionToken: sessionToken,\n        }),\n      transactionId,\n    },\n    client\n  );\n};\n","/* eslint-disable func-style -- javascript requires this to be a function */\n\nimport { WalletProviderMethodUnavailableError } from '../../../../errors/WalletProviderMethodUnavailableError';\nimport type { WalletProvider } from '../../walletProvider/walletProvider.types';\n\n/**\n * Asserts that a specific wallet provider method is defined, throwing an error if it's not.\n * This function acts as a type guard, narrowing the type to ensure the method exists.\n *\n * @template T - The specific wallet provider method key being checked\n * @param walletProvider - The wallet provider object to check\n * @param methodName - The name of the method to check for availability\n * @throws Throws WalletProviderMethodUnavailableError if the method is not defined\n * @example\n * ```typescript\n * const walletProvider: WalletProvider = getWalletProvider();\n * assertWalletProviderMethodDefined(walletProvider, 'connect');\n * // walletProvider.connect is now guaranteed to be defined\n * await walletProvider.connect();\n * ```\n */\n// eslint-disable-next-line custom-rules/require-single-object-param\nexport function assertWalletProviderMethodDefined<\n  T extends keyof WalletProvider\n>(\n  walletProvider: WalletProvider,\n  methodName: T\n): asserts walletProvider is WalletProvider &\n  Required<Pick<WalletProvider, T>> {\n  if (walletProvider[methodName] === undefined) {\n    throw new WalletProviderMethodUnavailableError({\n      methodName: methodName as string,\n      walletProviderKey: walletProvider.key,\n    });\n  }\n}\n","export const SWAP_SUPPORTED_CHAINS = ['BTC', 'EVM', 'SOL', 'SUI', 'TRON'];\n","import { getCore } from '../../../../client/core/getCore';\nimport type { DynamicClient } from '../../../../client/types';\nimport type { WalletProvider } from '../../../wallets/walletProvider';\n\nexport type EnsureCorrectActiveNetworkParams = {\n  requiredNetworkId: string;\n  walletProvider: WalletProvider;\n};\n\n/**\n * Ensures the wallet provider is on the correct active network if possible.\n * If the wallet provider is not on the correct active network, it will try to switch to the correct active network.\n * It's not a blocker, so it will just log the error and skip the step if it fails.\n *\n * @not-instrumented\n */\nexport const ensureCorrectActiveNetwork = async (\n  { requiredNetworkId, walletProvider }: EnsureCorrectActiveNetworkParams,\n  client: DynamicClient\n) => {\n  const { logger } = getCore(client);\n\n  // Skip if no network id to switch to or the wallet provider doesn't support network switching\n  if (!requiredNetworkId || !walletProvider.switchActiveNetwork) {\n    return;\n  }\n\n  logger.debug(\n    '[ensureCorrectActiveNetwork] Required network id',\n    requiredNetworkId\n  );\n\n  try {\n    const { networkId: activeNetworkId } =\n      await walletProvider.getActiveNetworkId();\n\n    logger.debug(\n      '[ensureCorrectActiveNetwork] Check if should switch network',\n      {\n        activeNetworkId,\n        requiredNetworkId,\n      }\n    );\n\n    if (!activeNetworkId || activeNetworkId === requiredNetworkId) {\n      logger.debug(\n        '[ensureCorrectActiveNetwork] No active network id found or active network id is the same as the required network id - skipping this step'\n      );\n      return;\n    }\n\n    await walletProvider.switchActiveNetwork({\n      networkId: requiredNetworkId,\n    });\n  } catch (error) {\n    // intentionally swallowed: network switching is best-effort and the swap\n    // should proceed even if we can't verify or change the active network\n    logger.debug(\n      '[ensureCorrectActiveNetwork] Error getting active network id or switching network - skipping this step',\n      error\n    );\n  }\n};\n","import { getDefaultClient } from '../../../client/defaultClient';\nimport { InvalidParamError } from '../../../errors/InvalidParamError';\nimport { assertWalletProviderMethodDefined } from '../../wallets/utils/assertWalletProviderMethodDefined';\nimport { getWalletProviderFromWalletAccount } from '../../wallets/utils/getWalletProviderFromWalletAccount';\nimport type { WalletAccount } from '../../wallets/walletAccount';\nimport { SWAP_SUPPORTED_CHAINS } from '../constants';\nimport type { SwapTransactionSigningPayload } from '../swap.types';\nimport { ensureCorrectActiveNetwork } from '../utils/ensureCorrectActiveNetwork';\n\nexport type ExecuteSwapTransactionParams = {\n  /**\n   * The callback to invoke when the transaction execution step changes.\n   *\n   * 'approval' - The approval step begins. (only happens for ERC-20 tokens when the allowance is insufficient)\n   * 'transaction' - The transaction step begins.\n   */\n  onStepChange?: (step: 'approval' | 'transaction') => void;\n  /**\n   * The signing payload for the swap transaction.\n   * Usually obtained from a `getSwapQuote` call.\n   */\n  signingPayload: SwapTransactionSigningPayload;\n  /**\n   * Controls whether the swap is routed through Dynamic's gas sponsorship.\n   *\n   * - `'auto'` (default): the swap is sponsored when gas sponsorship is enabled\n   *   for the chain AND the wallet is a Dynamic embedded wallet. Otherwise the\n   *   user pays gas.\n   * - `'off'`: the swap is never sponsored, regardless of project settings or\n   *   wallet capabilities. The user pays gas.\n   *\n   * @default 'auto'\n   */\n  sponsorshipMode?: 'auto' | 'off';\n  /**\n   * The wallet account to execute the swap transaction on.\n   */\n  walletAccount: WalletAccount;\n};\n\n/**\n * Executes a swap transaction\n *\n * @param params ExecuteSwapTransactionParams - The parameters for the swap transaction.\n * @param [client] - The Dynamic client instance. Only required when using multiple Dynamic clients.\n * @returns The transaction hash.\n * @instrumented\n */\nexport const executeSwapTransaction = async (\n  {\n    walletAccount,\n    signingPayload,\n    onStepChange,\n    sponsorshipMode,\n  }: ExecuteSwapTransactionParams,\n  client = getDefaultClient()\n): Promise<{ transactionHash: string }> => {\n  if (!SWAP_SUPPORTED_CHAINS.includes(walletAccount.chain)) {\n    throw new InvalidParamError(\n      `Chain ${walletAccount.chain} is not supported for swap transactions`\n    );\n  }\n\n  const walletProvider = getWalletProviderFromWalletAccount(\n    { walletAccount },\n    client\n  );\n\n  assertWalletProviderMethodDefined(walletProvider, 'executeSwapTransaction');\n\n  await ensureCorrectActiveNetwork(\n    {\n      requiredNetworkId: signingPayload.chainId,\n      walletProvider,\n    },\n    client\n  );\n\n  const { transactionHash } = await walletProvider.executeSwapTransaction({\n    onStepChange,\n    signingPayload,\n    sponsorshipMode,\n    walletAccount,\n  });\n\n  return { transactionHash };\n};\n","import { getDefaultClient } from '../../../client/defaultClient';\nimport { assertDefined } from '../../../utils/assertDefined';\nimport { executeSwapTransaction } from '../../swap/executeSwapTransaction';\nimport type { WalletAccount } from '../../wallets/walletAccount';\nimport { broadcastCheckoutTransaction } from '../broadcastCheckoutTransaction';\nimport type { CheckoutTransaction } from '../checkout.types';\nimport type { PrepareCheckoutTransactionParams } from '../prepareCheckoutTransaction';\nimport { prepareCheckoutTransaction } from '../prepareCheckoutTransaction';\n\nexport type SubmitCheckoutTransactionParams = {\n  onStepChange?: (step: 'approval' | 'transaction') => void;\n  transactionId: string;\n  walletAccount: WalletAccount;\n} & PrepareCheckoutTransactionParams;\n\n/**\n * Prepares, signs, and broadcasts a checkout transaction in one call.\n *\n * Orchestrates the full submission flow:\n * 1. Calls prepareCheckoutTransaction to advance to signing state and lock the quote\n * 2. Ensures the wallet is on the correct network for the transaction\n * 3. Delegates on-chain signing to the wallet provider's executeSwapTransaction method\n * 4. Calls broadcastCheckoutTransaction with the resulting txHash\n *\n * @param params SubmitCheckoutTransactionParams - The transaction ID, wallet account, and optional step callback.\n * @param [client] - The Dynamic client instance. Only required when using multiple Dynamic clients.\n * @returns The broadcasted checkout transaction\n * @instrumented\n */\nexport const submitCheckoutTransaction = async (\n  {\n    onStepChange,\n    transactionId,\n    walletAccount,\n    assertBalanceForGasCost,\n    assertBalanceForTransferAmount,\n  }: SubmitCheckoutTransactionParams,\n  client = getDefaultClient()\n): Promise<CheckoutTransaction> => {\n  const prepared = await prepareCheckoutTransaction(\n    { assertBalanceForGasCost, assertBalanceForTransferAmount, transactionId },\n    client\n  );\n\n  const signingPayload = prepared.quote?.signingPayload;\n\n  assertDefined(\n    signingPayload,\n    'No signing payload returned from prepare — quote may be missing transaction data'\n  );\n\n  const { transactionHash } = await executeSwapTransaction(\n    {\n      onStepChange,\n      signingPayload,\n      walletAccount,\n    },\n    client\n  );\n\n  return broadcastCheckoutTransaction(\n    { transactionId, txHash: transactionHash },\n    client\n  );\n};\n","import { getDefaultClient } from '../../../client/defaultClient';\nimport type { DynamicClient } from '../../../client/types';\n// TODO(realtime): Re-enable the realtime subscribe call once the Ably API key\n// is provisioned in the dashboard-api environment. The `realtime/auth`\n// endpoint currently returns \"Realtime service is not configured\" for\n// environments without Ably wiring, so we are temporarily turning this into\n// a no-op to avoid surfacing connection errors to customers. See\n// https://dynamiclabsgroup.slack.com/archives/C03DWBF0LE8/p1778590548698209\n// import { subscribeToCheckoutTransaction } from '../utils/subscribeToCheckoutTransaction';\n\nexport type TrackCheckoutTransactionParams = {\n  transactionId: string;\n};\n\n/**\n * Subscribes to realtime `checkoutTransactionExecutionStateChanged` and\n * `checkoutTransactionSettlementStateChanged` events for an existing\n * checkout transaction.\n *\n * This is only needed after a page refresh to re-establish the subscription.\n * Transactions created with {@link createCheckoutTransaction} are automatically\n * subscribed — calling this again for those is unnecessary unless the page\n * has been reloaded.\n *\n * NOTE: Temporarily a no-op while the Ably API key is being provisioned for\n * the realtime checkout transaction channel. Will be re-enabled once the\n * dashboard-api environment has the Ably wiring in place.\n *\n * @param params.transactionId - The ID of the checkout transaction to track.\n * @param [client] - The Dynamic client instance. Only required when using multiple Dynamic clients.\n * @not-instrumented\n */\nexport const trackCheckoutTransaction = (\n  _params: TrackCheckoutTransactionParams,\n  // eslint-disable-next-line @typescript-eslint/no-unused-vars\n  client: DynamicClient = getDefaultClient()\n): Promise<void> => {\n  // TODO(realtime): Re-enable once the Ably API key is configured. See the\n  // import block above for context.\n  // return subscribeToCheckoutTransaction({ transactionId }, client);\n  return Promise.resolve();\n};\n","import { getDefaultClient } from '../../../../client/defaultClient';\nimport { InvalidParamError } from '../../../../errors/InvalidParamError';\nimport { assertDefined } from '../../../../utils/assertDefined';\nimport type { CheckoutTransaction } from '../../checkout.types';\nimport { getCheckouts } from '../../getCheckouts';\n\nexport type RequiresConversionParams = {\n  transaction: CheckoutTransaction;\n};\n\n/**\n * Determines whether a token conversion (swap/bridge) is required for a checkout transaction.\n *\n * Returns `true` when the from token does not match any settlement token defined in\n * the checkout's settlement config for the given chain — meaning the asset must be\n * converted before it can settle.\n * Returns `false` when the from token already matches a settlement token, so no\n * conversion is needed.\n *\n * @param params - The from token details and the checkout's settlement config.\n * @param [client] - The Dynamic client instance. Only required when using multiple Dynamic clients.\n * @returns Whether a token conversion is required\n * @not-instrumented\n */\nexport const requiresConversion = async (\n  { transaction }: RequiresConversionParams,\n  client = getDefaultClient()\n): Promise<boolean> => {\n  if (\n    !transaction.fromChainId ||\n    !transaction.fromChainName ||\n    !transaction.fromToken\n  ) {\n    throw new InvalidParamError(\n      'Transaction is missing source information. Make sure that attachCheckoutTransactionSource has been called before calling this function.'\n    );\n  }\n\n  const allCheckouts = await getCheckouts(client);\n\n  const checkout = allCheckouts.find(\n    (checkout) => checkout.id === transaction.checkoutId\n  );\n\n  assertDefined(\n    checkout,\n    'Could not find checkout associated with transaction.'\n  );\n\n  return !checkout.settlementConfig.settlements.some(\n    (settlement) =>\n      settlement.chainName === transaction.fromChainName &&\n      settlement.chainId === transaction.fromChainId &&\n      settlement.tokenAddress === transaction.fromToken\n  );\n};\n","import type { VerifyResponse } from '@dynamic-labs/sdk-api-core';\n\nimport { getCore } from '../../../client/core/getCore';\nimport { getDefaultClient } from '../../../client/defaultClient';\nimport { assertDefined } from '../../../utils/assertDefined';\nimport { createApiClient } from '../../apiClient';\nimport { updateAuthFromVerifyResponse } from '../../auth/updateAuthFromVerifyResponse';\nimport { emitEvent } from '../../clientEvents';\n\nconst DEVICE_REGISTRATION_TOKEN_HEADER = 'x-dynamic-device-registration-token';\n\ntype CompleteDeviceRegistrationParams = {\n  deviceToken: string;\n};\n\n/** @instrumented */\nexport const completeDeviceRegistration = async (\n  { deviceToken }: CompleteDeviceRegistrationParams,\n  client = getDefaultClient()\n): Promise<VerifyResponse> => {\n  assertDefined(deviceToken, 'deviceToken is required');\n\n  const core = getCore(client);\n  const apiClient = createApiClient(\n    {\n      headers: {\n        [DEVICE_REGISTRATION_TOKEN_HEADER]: deviceToken,\n      },\n    },\n    client\n  );\n\n  const response = await apiClient.deviceRegistration({\n    environmentId: core.environmentId,\n  });\n\n  updateAuthFromVerifyResponse({ response }, client);\n\n  // Emit event after successful registration\n  emitEvent({ event: 'deviceRegistrationCompleted' }, client);\n\n  return response;\n};\n","import { InvalidDeviceRegistrationRedirectError } from '../../../errors/InvalidDeviceRegistrationRedirectError';\n\ntype GetDeviceRegistrationTokenFromUrlParams = {\n  url: string;\n};\n\n/**\n * Safely extracts the device token from a device registration redirect URL.\n *\n * This function validates that the URL is a valid device registration redirect\n * then extracts and returns the deviceToken.\n *\n * @returns The device token as a string if valid.\n * @throws InvalidDeviceRegistrationRedirectError If the URL is not a valid device registration redirect.\n  * @not-instrumented\n */\nexport const getDeviceRegistrationTokenFromUrl = ({\n  url,\n}: GetDeviceRegistrationTokenFromUrlParams): string => {\n  let urlObject: URL;\n\n  try {\n    urlObject = new URL(url);\n  } catch {\n    throw new InvalidDeviceRegistrationRedirectError();\n  }\n\n  const deviceRegistrationToken = urlObject.searchParams.get(\n    'deviceRegistrationToken'\n  );\n\n  if (!deviceRegistrationToken || deviceRegistrationToken.trim() === '') {\n    throw new InvalidDeviceRegistrationRedirectError();\n  }\n\n  return deviceRegistrationToken;\n};\n","import { getDeviceRegistrationTokenFromUrl } from '../getDeviceRegistrationTokenFromUrl';\n\ntype DetectDeviceRegistrationRedirectParams = {\n  url: string;\n};\n\n/**\n * Detects if the current URL is a device registration redirect.\n *\n * This function uses getDeviceRegistrationTokenFromUrl to validate the URL and determine\n * if it contains device registration redirect data from a device authentication flow.\n *\n * @returns True if the URL is a device registration redirect, false otherwise.\n  * @not-instrumented\n */\nexport const detectDeviceRegistrationRedirect = ({\n  url,\n}: DetectDeviceRegistrationRedirectParams): boolean => {\n  try {\n    getDeviceRegistrationTokenFromUrl({ url });\n    return true;\n  } catch {\n    return false;\n  }\n};\n","import type { DeviceRegistrationResponse } from '@dynamic-labs/sdk-api-core';\n\nimport { getCore } from '../../../client/core/getCore';\nimport { getDefaultClient } from '../../../client/defaultClient';\nimport { UnauthorizedError } from '../../../errors/UnauthorizedError';\nimport { createApiClient } from '../../apiClient';\n\n/** @not-instrumented */\nexport const getRegisteredDevices = async (\n  client = getDefaultClient()\n): Promise<DeviceRegistrationResponse[]> => {\n  const core = getCore(client);\n  const apiClient = createApiClient({}, client);\n\n  try {\n    const response = await apiClient.listDeviceRegistrations({\n      environmentId: core.environmentId,\n    });\n\n    return response.deviceRegistrations;\n  } catch (error) {\n    /**\n     * The API will return 401 when no devices are registered when there are no\n     * devices registered. We need to handle this case gracefully.\n     */\n    if (error instanceof UnauthorizedError) {\n      return [];\n    }\n\n    throw error;\n  }\n};\n","import type { User } from '../../user/user.types';\n\n/**\n * Checks if device registration is required for the given user.\n *\n * This function determines if the user has the deviceRegistration\n * scope, indicating that device registration is required.\n *\n * @param user - The user to check.\n * @returns True if device registration is required, false otherwise.\n  * @not-instrumented\n */\nexport const isDeviceRegistrationRequired = (user: User) =>\n  Boolean(user.scope?.includes('device:register'));\n","import { getCore } from '../../../client/core/getCore';\nimport { getDefaultClient } from '../../../client/defaultClient';\nimport { createApiClient } from '../../apiClient';\nimport { logoutWithReason } from '../../auth/logoutWithReason';\n\n/** @instrumented */\nexport const revokeAllRegisteredDevices = async (\n  client = getDefaultClient()\n): Promise<void> => {\n  const core = getCore(client);\n  const apiClient = createApiClient({}, client);\n\n  await apiClient.deleteAllDeviceRegistrations({\n    environmentId: core.environmentId,\n  });\n\n  await logoutWithReason({ reason: 'all-devices-revoked' }, client);\n};\n","import { getCore } from '../../../client/core/getCore';\nimport { getDefaultClient } from '../../../client/defaultClient';\nimport { assertDefined } from '../../../utils/assertDefined';\nimport { createApiClient } from '../../apiClient';\nimport { logoutWithReason } from '../../auth/logoutWithReason';\n\ntype RevokeRegisteredDeviceParams = {\n  deviceRegistrationId: string;\n};\n\n/** @instrumented */\nexport const revokeRegisteredDevice = async (\n  { deviceRegistrationId }: RevokeRegisteredDeviceParams,\n  client = getDefaultClient()\n): Promise<void> => {\n  assertDefined(deviceRegistrationId, 'deviceRegistrationId is required');\n\n  const core = getCore(client);\n  const apiClient = createApiClient({}, client);\n\n  const response = await apiClient.deleteDeviceRegistration({\n    deviceRegistrationId,\n    environmentId: core.environmentId,\n  });\n\n  if (response.currentDeviceRevoked) {\n    await logoutWithReason({ reason: 'device-revoked' }, client);\n  }\n};\n","/* eslint-disable no-restricted-globals */\n\nimport { getCore } from '../../../../client/core/getCore';\nimport { getDefaultClient } from '../../../../client/defaultClient';\nimport { ValueMustBeDefinedError } from '../../../../errors/ValueMustBeDefinedError';\n\ntype AddCoinbaseOnrampOrderEventListenerParams = {\n  listener: (event: {\n    data: Record<string, unknown>;\n    eventName: string;\n  }) => void;\n};\n\n/**\n * Adds a listener for Coinbase onramp order events.\n *\n * @param params.listener - The listener function to call when an event is received.\n * @param [client] - The Dynamic client instance. Only required when using multiple Dynamic clients.\n * @returns A function to remove the listener.\n * @throws {ValueMustBeDefinedError} If the window is not available.\n * @docs https://docs.cdp.coinbase.com/onramp-&-offramp/onramp-apis/apple-pay-onramp-api#events-names\n  * @not-instrumented\n */\nexport const addCoinbaseOnrampOrderEventListener = (\n  { listener }: AddCoinbaseOnrampOrderEventListenerParams,\n  client = getDefaultClient()\n): VoidFunction => {\n  const core = getCore(client);\n\n  if (typeof window === 'undefined') {\n    throw new ValueMustBeDefinedError(\n      'Window is not available to listen for Coinbase onramp order events'\n    );\n  }\n\n  const handleMessageEvent = (event: MessageEvent) => {\n    if (event.origin !== 'https://pay.coinbase.com') {\n      return;\n    }\n\n    core.logger.debug(\n      '[addCoinbaseOnrampOrderEventListener] pay.coinbase.com event received',\n      { event }\n    );\n\n    try {\n      const coinbaseOnrampOrderEventData = JSON.parse(event.data);\n\n      if (!coinbaseOnrampOrderEventData.eventName?.startsWith('onramp_api.')) {\n        return;\n      }\n\n      listener({\n        data: coinbaseOnrampOrderEventData.data,\n        eventName: coinbaseOnrampOrderEventData.eventName,\n      });\n    } catch (error) {\n      core.logger.debug(\n        '[addCoinbaseOnrampOrderEventListener] Failed to parse Coinbase onramp order event data',\n        {\n          error,\n        }\n      );\n    }\n  };\n\n  window.addEventListener('message', handleMessageEvent);\n\n  return () => {\n    window.removeEventListener('message', handleMessageEvent);\n  };\n};\n","import { JwtVerifiedCredentialFormatEnum } from '@dynamic-labs/sdk-api-core';\n\nimport { getDefaultClient } from '../../../../client/defaultClient';\nimport { InvalidParamError } from '../../../../errors/InvalidParamError';\nimport { assertDefined } from '../../../../utils/assertDefined';\nimport type {\n  CoinbaseOnrampOrderPaymentMethod,\n  FieldMissingVerificationForCoinbaseOnramp,\n} from '../coinbase.types';\n\ntype GetMissingVerificationForCoinbaseOnrampOrderResponse =\n  FieldMissingVerificationForCoinbaseOnramp[];\n\ntype GetMissingVerificationForCoinbaseOnrampOrderParams = {\n  paymentMethod: CoinbaseOnrampOrderPaymentMethod;\n};\n\n/**\n * This function is used to get a list of fields that are missing verification for a Coinbase onramp order\n *\n * - If the user is missing information for an email or phone number, the field will be returned with the error code MISSING_INFORMATION\n * - If the user is missing verification for an email or phone number, the field will be returned with the error code MISSING_VERIFICATION\n *   and the existing unverified email or phone number will be included in the data field.\n * - If the user's phone number has not been verified in the last 60 days, the field will be returned with the error code VERIFICATION_EXPIRED\n *   and the existing phone number will be included in the data field.\n *\n * @param params.paymentMethod - The payment method that will be used to create the onramp order\n * @param [client] - The Dynamic client instance. Only required when using multiple Dynamic clients.\n * @returns FieldMissingVerificationForCoinbaseOnramp[] - An array of fields that are missing verification for a Coinbase onramp order\n * @throws {InvalidParamError} - If the payment method is not valid\n * @throws {ValueMustBeDefinedError} - If the user is not authenticated\n  * @not-instrumented\n */\nexport const getMissingVerificationForCoinbaseOnrampOrder = (\n  { paymentMethod }: GetMissingVerificationForCoinbaseOnrampOrderParams,\n  client = getDefaultClient()\n): GetMissingVerificationForCoinbaseOnrampOrderResponse => {\n  // adding the payment method as a param for now just so a user has to pass an object as the first param\n  // that way, when we add more payment methods, we can easily add them to the param object\n  // and not have to change the function signature\n  if (paymentMethod !== 'GUEST_CHECKOUT_APPLE_PAY') {\n    throw new InvalidParamError(`Invalid payment method: ${paymentMethod}`);\n  }\n\n  const { user } = client;\n\n  assertDefined(user, 'User is not authenticated');\n\n  const fieldsMissingVerification: FieldMissingVerificationForCoinbaseOnramp[] =\n    [];\n\n  const emailVerifiedCredential = user.verifiedCredentials.find(\n    (credential) => credential.format === JwtVerifiedCredentialFormatEnum.Email\n  );\n\n  if (!user.email) {\n    // when user has no email at all (verified or not)\n    fieldsMissingVerification.push({\n      errorCode: 'MISSING_INFORMATION',\n      field: 'email',\n    });\n  } else if (!emailVerifiedCredential) {\n    // when user has an email but it is not verified\n    fieldsMissingVerification.push({\n      data: user.email,\n      errorCode: 'MISSING_VERIFICATION',\n      field: 'email',\n    });\n  }\n\n  const phoneVerifiedCredential = user.verifiedCredentials.find(\n    (credential) =>\n      credential.format === JwtVerifiedCredentialFormatEnum.PhoneNumber\n  );\n\n  const phoneNumberVerifiedInPast60Days =\n    phoneVerifiedCredential?.verifiedAt &&\n    phoneVerifiedCredential.verifiedAt >=\n      new Date(Date.now() - 60 * 24 * 60 * 60 * 1000);\n\n  if (!user.phoneNumber) {\n    // when user has no phone number at all (verified or not)\n    fieldsMissingVerification.push({\n      errorCode: 'MISSING_INFORMATION',\n      field: 'phoneNumber',\n    });\n  } else if (!phoneVerifiedCredential) {\n    // when user has a phone number but it is not verified\n    fieldsMissingVerification.push({\n      data: user.phoneNumber,\n      errorCode: 'MISSING_VERIFICATION',\n      field: 'phoneNumber',\n    });\n  } else if (!phoneNumberVerifiedInPast60Days) {\n    // when user has a verified phone number but it is not verified in the last 60 days\n    fieldsMissingVerification.push({\n      data: user.phoneNumber,\n      errorCode: 'VERIFICATION_EXPIRED',\n      field: 'phoneNumber',\n    });\n  }\n\n  return fieldsMissingVerification;\n};\n","import { type SdkUser } from '@dynamic-labs/sdk-api-core';\n\nimport type { DynamicClient } from '../../../../../client/types/DynamicClient';\nimport { MissingUserVerificationError } from '../../../../../errors/MissingUserVerificationError';\nimport { assertDefined } from '../../../../../utils/assertDefined';\nimport { getMissingVerificationForCoinbaseOnrampOrder } from '../../getMissingVerificationForCoinbaseOnrampOrder';\n\n/** @not-instrumented */\nexport const validateUserCredentialsForCoinbaseOnrampOrder = (\n  client: DynamicClient\n): SdkUser => {\n  const { user } = client;\n\n  assertDefined(user, 'User is not authenticated');\n\n  const fieldsMissingVerification =\n    getMissingVerificationForCoinbaseOnrampOrder(\n      { paymentMethod: 'GUEST_CHECKOUT_APPLE_PAY' },\n      client\n    );\n\n  const missingEmailVerification = fieldsMissingVerification.find(\n    (field) => field.field === 'email'\n  );\n\n  if (missingEmailVerification) {\n    throw new MissingUserVerificationError({\n      informationToVerify: 'email',\n      message:\n        'User must have a verified email to create a Coinbase onramp order',\n    });\n  }\n\n  const missingPhoneNumberVerification = fieldsMissingVerification.find(\n    (field) => field.field === 'phoneNumber'\n  );\n\n  if (\n    missingPhoneNumberVerification &&\n    missingPhoneNumberVerification.errorCode !== 'VERIFICATION_EXPIRED'\n  ) {\n    throw new MissingUserVerificationError({\n      informationToVerify: 'phoneNumber',\n      message:\n        'User must have a verified phone number to create a Coinbase onramp order',\n    });\n  }\n\n  // this is a requirement for Coinbase Onramp\n  // https://docs.cdp.coinbase.com/api-reference/v2/rest-api/onramp/create-an-onramp-order#body-phone-number-verified-at\n  if (\n    missingPhoneNumberVerification &&\n    missingPhoneNumberVerification.errorCode === 'VERIFICATION_EXPIRED'\n  ) {\n    throw new MissingUserVerificationError({\n      informationToVerify: 'phoneNumber',\n      message:\n        \"The user's phone number has not been verified in the last 60 days. Please re-verify the user's phone number\",\n    });\n  }\n\n  return user;\n};\n","import type { CoinbaseOnrampOrderPaymentMethod } from '@dynamic-labs/sdk-api-core';\n\nimport { getCore } from '../../../../client/core/getCore';\nimport { getDefaultClient } from '../../../../client/defaultClient';\nimport { createApiClient } from '../../../apiClient';\nimport type {\n  CoinbaseCreateOnrampOrderRequest,\n  CoinbaseOnrampOrderResponse,\n} from '../coinbase.types';\nimport { validateUserCredentialsForCoinbaseOnrampOrder } from '../utils/validateUserCredentialsForCoinbaseOnrampOrder';\n\n/**\n * Creates a Coinbase onramp order\n *\n * @param orderParams CoinbaseCreateOnrampOrderRequest - The parameters for the onramp order.\n * @param [client] - The Dynamic client instance. Only required when using multiple Dynamic clients.\n * @returns The created order\n * @throws {MissingUserVerificationError} If the user is missing verification for email or phone\n  * @instrumented\n */\nexport const createCoinbaseOnrampOrder = async (\n  orderParams: CoinbaseCreateOnrampOrderRequest,\n  client = getDefaultClient()\n): Promise<CoinbaseOnrampOrderResponse> => {\n  const user = validateUserCredentialsForCoinbaseOnrampOrder(client);\n\n  const core = getCore(client);\n  const apiClient = createApiClient({ includeMfaToken: true }, client);\n\n  const { isSandbox, ...restOrderParams } = orderParams;\n\n  const orderResponse = await apiClient.createCoinbaseOnrampOrder({\n    coinbaseOnrampOrderCreateRequest: {\n      ...restOrderParams,\n      // to create a sandbox order, we need to prefix the partner user ref with 'sandbox-'\n      // https://docs.cdp.coinbase.com/onramp-&-offramp/onramp-apis/apple-pay-onramp-api#testing\n      partnerUserRef:\n        orderParams.partnerUserRef ??\n        (isSandbox ? `sandbox-${user.id}` : user.id),\n      paymentMethod:\n        orderParams.paymentMethod as CoinbaseOnrampOrderPaymentMethod,\n    },\n    environmentId: core.environmentId,\n  });\n\n  if (!isSandbox || !orderResponse.paymentLink) {\n    return orderResponse;\n  }\n\n  return {\n    ...orderResponse,\n    paymentLink: {\n      ...orderResponse.paymentLink,\n      url: `${orderResponse.paymentLink.url}&useApplePaySandbox=true`,\n    },\n  };\n};\n","import { getCore } from '../../../../client/core/getCore';\nimport { getDefaultClient } from '../../../../client/defaultClient';\nimport { createApiClient } from '../../../apiClient';\nimport type {\n  CoinbaseOnrampGetBuyUrlRequest,\n  CoinbaseOnrampGetBuyUrlResponse,\n} from '../coinbase.types';\n\n/**\n * Gets a Coinbase buy URL\n *\n * @param buyUrlParams CoinbaseOnrampGetBuyUrlRequest - The parameters for the buy URL.\n * @param [client] - The Dynamic client instance. Only required when using multiple Dynamic clients.\n * @returns an object containing the buy URL\n  * @not-instrumented\n */\nexport const getCoinbaseBuyUrl = async (\n  buyUrlParams: CoinbaseOnrampGetBuyUrlRequest,\n  client = getDefaultClient()\n): Promise<CoinbaseOnrampGetBuyUrlResponse> => {\n  const core = getCore(client);\n  const apiClient = createApiClient({ includeMfaToken: true }, client);\n\n  const response = await apiClient.generateCoinbaseOnrampBuyUrl({\n    coinbaseOnrampGetBuyUrlRequest: buyUrlParams,\n    environmentId: core.environmentId,\n  });\n\n  return response;\n};\n","import type { ChainEnum } from '@dynamic-labs/sdk-api-core';\n\nimport { getCore } from '../../../../client/core/getCore';\nimport { getDefaultClient } from '../../../../client/defaultClient';\nimport { createApiClient } from '../../../apiClient';\nimport type {\n  CryptoDotComPaymentCreateRequest,\n  CryptoDotComPaymentResponse,\n} from '../cryptoDotCom.types';\n\n/**\n * Creates a crypto.com payment\n *\n * @param paymentParams CryptoDotComPaymentCreateRequest - The parameters for the payment.\n * @param [client] - The Dynamic client instance. Only required when using multiple Dynamic clients.\n * @returns The created payment\n  * @instrumented\n */\nexport const createCryptoDotComPayment = async (\n  paymentParams: CryptoDotComPaymentCreateRequest,\n  client = getDefaultClient()\n): Promise<CryptoDotComPaymentResponse> => {\n  const core = getCore(client);\n  const apiClient = createApiClient({ includeMfaToken: true }, client);\n\n  const response = await apiClient.createCryptoDotComPayment({\n    cryptoDotComPaymentCreateRequest: {\n      ...paymentParams,\n      // eslint-disable-next-line custom-rules/ban-chain-enum\n      chain: paymentParams.chain as ChainEnum,\n    },\n    environmentId: core.environmentId,\n  });\n\n  return response;\n};\n","/* eslint-disable custom-rules/ban-chain-enum */\nimport type { ChainEnum } from '@dynamic-labs/sdk-api-core';\n\nimport { getCore } from '../../../../client/core/getCore';\nimport { getDefaultClient } from '../../../../client/defaultClient';\nimport type { DynamicClient } from '../../../../client/types';\nimport { createApiClient } from '../../../apiClient';\nimport type { GetMoonPayCurrenciesParams, MoonPayCurrency } from '../moonpay.types';\n\n/**\n * Fetches the list of crypto currencies supported by MoonPay for the given chain\n * and network, filtered to active currencies only. Requires a MoonPay publishable\n * API key to be configured for the environment.\n *\n * @param params - The chain and optional network ID to filter currencies by.\n * @param [client] - The Dynamic client instance. Only required when using multiple Dynamic clients.\n * @returns An array of supported MoonPay currencies.\n * @instrumented\n */\nexport const getMoonPayCurrencies = async (\n  params: GetMoonPayCurrenciesParams,\n  client: DynamicClient = getDefaultClient()\n): Promise<MoonPayCurrency[]> => {\n  const core = getCore(client);\n  const apiClient = createApiClient({ includeMfaToken: true }, client);\n\n  const response = await apiClient.getMoonPayCurrencies({\n    // Chain is typed as ChainEnum in the generated API client; our public type\n    // is Chain (string literal union). The values are identical at runtime.\n    chain: params.chain as unknown as ChainEnum,\n    environmentId: core.environmentId,\n    ...(params.networkId ? { networkId: params.networkId } : {}),\n  });\n\n  return response.currencies ?? [];\n};\n","import { BaseError } from '../../../../errors/base';\n\nexport class MoonPayInvalidUrlError extends BaseError {\n  constructor() {\n    super({\n      cause: null,\n      code: 'moonpay_invalid_url_error',\n      docsUrl: null,\n      name: 'MoonPayInvalidUrlError',\n      shortMessage:\n        'MoonPay is configured but returned an invalid or untrusted URL. This may indicate a misconfiguration — please contact support if the issue persists.',\n    });\n  }\n}\n","import { BaseError } from '../../../../errors/base';\n\nexport class MoonPayProviderNotAvailableError extends BaseError {\n  constructor() {\n    super({\n      cause: null,\n      code: 'moonpay_provider_not_available_error',\n      docsUrl: null,\n      name: 'MoonPayProviderNotAvailableError',\n      shortMessage:\n        'MoonPay provider not available. Ensure MoonPay is enabled and a publishable API key is configured in the Dynamic dashboard.',\n    });\n  }\n}\n","import { ProviderEnum } from '@dynamic-labs/sdk-api-core';\n\nimport { getCore } from '../../../../client/core/getCore';\nimport { getDefaultClient } from '../../../../client/defaultClient';\nimport type { DynamicClient } from '../../../../client/types';\nimport { createApiClient } from '../../../apiClient';\nimport { MoonPayInvalidUrlError } from '../errors/MoonPayInvalidUrlError';\nimport { MoonPayProviderNotAvailableError } from '../errors/MoonPayProviderNotAvailableError';\nimport type { GetMoonPayUrlParams } from '../moonpay.types';\n\n/**\n * Returns the signed MoonPay URL for the given wallet and token.\n *\n * Uses the Dynamic onramp API to retrieve the pre-signed URL that can be\n * opened in a browser tab to allow the user to purchase crypto via MoonPay.\n *\n * @param params - Parameters including chain, wallet address, and optional token/currency filters.\n * @param [client] - The Dynamic client instance. Only required when using multiple Dynamic clients.\n * @returns The signed MoonPay URL.\n * @instrumented\n */\nexport const getMoonPayUrl = async (\n  params: GetMoonPayUrlParams,\n  client: DynamicClient = getDefaultClient()\n): Promise<string> => {\n  const core = getCore(client);\n  const apiClient = createApiClient({ includeMfaToken: true }, client);\n\n  const response = await apiClient.getSupportedOnramps({\n    chain: params.chain,\n    currency: params.currency,\n    environmentId: core.environmentId,\n    includeDisabled: true,\n    merchantName: params.merchantName,\n    networkId: params.networkId,\n    token: params.token,\n    tokenAmount: params.tokenAmount,\n    walletAddress: params.walletAddress,\n  });\n\n  const moonPayProvider = response.onramps?.find(\n    (provider) => provider.provider === ProviderEnum.MoonPay\n  );\n\n  if (!moonPayProvider?.url) {\n    throw new MoonPayProviderNotAvailableError();\n  }\n\n  // Validate scheme and host before returning — the URL is opened in a browser tab\n  // and a compromised API response could inject a javascript: URI or phishing URL.\n  // Use exact match or dot-prefixed subdomain check to block lookalikes like evilmoonpay.com.\n  const parsedUrl = new URL(moonPayProvider.url);\n  const isValidHost =\n    parsedUrl.hostname === 'moonpay.com' || parsedUrl.hostname.endsWith('.moonpay.com');\n  if (parsedUrl.protocol !== 'https:' || !isValidHost) {\n    core.logger.error('[getMoonPayUrl] Invalid URL returned by onramp API', {\n      url: moonPayProvider.url,\n    });\n    throw new MoonPayInvalidUrlError();\n  }\n\n  return moonPayProvider.url;\n};\n","import type { CreateExchangeTransferRequest } from '@dynamic-labs/sdk-api-core';\nimport { ExchangeKeyEnum } from '@dynamic-labs/sdk-api-core';\n\nimport { getCore } from '../../../../client/core/getCore';\nimport { getDefaultClient } from '../../../../client/defaultClient';\nimport { createApiClient } from '../../../apiClient';\nimport type { ExchangeTransferResponse } from '../kraken.types';\n\n// Kraken transfer request includes accountId + transfer parameters\nexport type KrakenTransferRequest = CreateExchangeTransferRequest & {\n  /**\n   * The Kraken account ID to transfer from (get from getKrakenAccounts)\n    * @instrumented\n */\n  accountId: string;\n};\n\n/**\n * Creates a Kraken exchange transfer to send crypto from a Kraken account to a whitelisted address\n *\n * @param transferParams - The parameters for the transfer including accountId\n * @param [client] - The Dynamic client instance. Only required when using multiple Dynamic clients.\n * @returns The created transfer\n  * @not-instrumented\n */\nexport const createKrakenExchangeTransfer = async (\n  transferParams: KrakenTransferRequest,\n  client = getDefaultClient()\n): Promise<ExchangeTransferResponse> => {\n  const core = getCore(client);\n  const apiClient = createApiClient({ includeMfaToken: true }, client);\n\n  const { accountId, ...createExchangeTransferRequest } = transferParams;\n\n  const response = await apiClient.postExchangeAccountTransfer({\n    accountId,\n    createExchangeTransferRequest,\n    environmentId: core.environmentId,\n    exchangeKey: ExchangeKeyEnum.Kraken,\n  });\n\n  return response;\n};\n","import type { ChainEnum } from '@dynamic-labs/sdk-api-core';\nimport { ExchangeKeyEnum } from '@dynamic-labs/sdk-api-core';\n\nimport { getCore } from '../../../../client/core/getCore';\nimport { getDefaultClient } from '../../../../client/defaultClient';\nimport { createApiClient } from '../../../apiClient';\nimport type { Chain } from '../../../chain';\nimport type { KrakenAccount } from '../kraken.types';\n\nexport type GetKrakenAccountsParams = {\n  /**\n   * Optional chain filter\n    * @not-instrumented\n */\n  chainName?: Chain;\n  /**\n   * Optional network ID filter\n   */\n  networkId?: number;\n};\n\n/**\n * Gets the Kraken accounts (balances) for the authenticated user\n *\n * @param [params] GetKrakenAccountsParams - Optional filters for the accounts.\n * @param [client] - The Dynamic client instance. Only required when using multiple Dynamic clients.\n * @returns Array of Kraken accounts with balances\n  * @not-instrumented\n */\nexport const getKrakenAccounts = async (\n  params?: GetKrakenAccountsParams,\n  client = getDefaultClient()\n): Promise<KrakenAccount[]> => {\n  const core = getCore(client);\n  const apiClient = createApiClient({ includeMfaToken: true }, client);\n\n  const response = await apiClient.getUserAccounts({\n    // eslint-disable-next-line custom-rules/ban-chain-enum\n    chainName: params?.chainName as ChainEnum,\n    environmentId: core.environmentId,\n    exchangeKey: ExchangeKeyEnum.Kraken,\n    networkId: params?.networkId,\n  });\n\n  return response;\n};\n","import { ExchangeKeyEnum } from '@dynamic-labs/sdk-api-core';\n\nimport { getCore } from '../../../../client/core/getCore';\nimport { getDefaultClient } from '../../../../client/defaultClient';\nimport { createApiClient } from '../../../apiClient';\nimport type { TransferDestinationResponse } from '../kraken.types';\n\n/**\n * Gets the whitelisted addresses for Kraken transfers\n *\n * @param [client] - The Dynamic client instance. Only required when using multiple Dynamic clients.\n * @returns Transfer destinations response with whitelisted addresses\n  * @not-instrumented\n */\nexport const getKrakenWhitelistedAddresses = async (\n  client = getDefaultClient()\n): Promise<TransferDestinationResponse> => {\n  const core = getCore(client);\n  const apiClient = createApiClient({ includeMfaToken: true }, client);\n\n  const response = await apiClient.getExchangeTransferDestinations({\n    environmentId: core.environmentId,\n    exchangeKey: ExchangeKeyEnum.Kraken,\n  });\n\n  return response;\n};\n","import { getCore } from '../../../client/core/getCore';\nimport { getDefaultClient } from '../../../client/defaultClient';\n\n/**\n * Allows waiting until all modules of the client have been properly initialized\n * and are ready for use.\n *\n * @returns a promise that resolves once the client is fully initialized.\n  * @not-instrumented\n */\nexport const waitForClientInitialized = async (client = getDefaultClient()) => {\n  const core = getCore(client);\n\n  await core.initTrack.waitForAll();\n};\n","import { getCore } from '../../../client/core/getCore';\nimport { getDefaultClient } from '../../../client/defaultClient';\nimport type { DynamicClient } from '../../../client/types';\n\nexport type SetInstrumentationEnabledOptions = {\n  /** Whether event collection should be active. */\n  enabled: boolean;\n};\n\n/**\n * Enables or disables event collection for the client's instrumentation service.\n *\n * When enabled, events are forwarded to the configured transport on every\n * instrumented function call. When disabled, instrumented functions run\n * normally but emit no telemetry.\n * @instrumented\n */\nexport const setInstrumentationEnabled = (\n  { enabled }: SetInstrumentationEnabledOptions,\n  client: DynamicClient = getDefaultClient()\n) => {\n  getCore(client).instrumentation.setEnabled(enabled);\n};\n","/**\n * Default CDN URL for the wallet book.\n  * @not-instrumented\n */\nconst DEFAULT_WALLET_BOOK_CDN_URL =\n  'https://dynamic-static-assets.com/wallet-book/v1/stable/wallet-book.json';\n\n/**\n * Gets the wallet book CDN URL from environment variables with fallback to default.\n *\n * Checks for environment variables in the following order:\n * 1. WALLET_BOOK_CDN_URL\n * 2. NEXT_PUBLIC_WALLET_BOOK_CDN_URL\n * 4. Default CDN URL\n *\n * @returns The wallet book CDN URL to use.\n  * @not-instrumented\n */\nexport const getWalletBookCdnUrl = (): string => {\n  if (typeof process !== 'undefined' && process.env) {\n    const envVar =\n      process.env.WALLET_BOOK_CDN_URL ||\n      process.env.NEXT_PUBLIC_WALLET_BOOK_CDN_URL;\n\n    if (envVar) {\n      return envVar;\n    }\n  }\n\n  return DEFAULT_WALLET_BOOK_CDN_URL;\n};\n","import { getCore } from '../../../../client/core/getCore';\nimport type { DynamicClient } from '../../../../client/types';\nimport { APIError } from '../../../../errors/APIError';\nimport { getWalletBookCdnUrl } from '../../getWalletBookCdnUrl';\nimport type { WalletBookSchema } from '../../legacyWalletBook.types';\n\n/**\n * The timeout for each fetch attempt in milliseconds.\n  * @not-instrumented\n */\nconst FETCH_TIMEOUT_MS = 30000; // 30 seconds\n\n/**\n * Fetches the wallet book from the CDN endpoint with timeout handling.\n *\n * @param client - The Dynamic client instance.\n * @returns A promise that resolves to the wallet book data.\n  * @not-instrumented\n */\nexport const fetchWithTimeout = async (\n  client: DynamicClient\n): Promise<WalletBookSchema> => {\n  const controller = new AbortController();\n  const timeoutId = setTimeout(() => controller.abort(), FETCH_TIMEOUT_MS);\n  const core = getCore(client);\n\n  try {\n    const response = await core.fetch(getWalletBookCdnUrl(), {\n      signal: controller.signal,\n    });\n\n    if (!response.ok) {\n      throw new APIError(\n        `Failed to fetch wallet book: ${response.status} ${response.statusText}`,\n        'wallet_book_fetch_error',\n        response.status\n      );\n    }\n\n    const data = (await response.json()) as WalletBookSchema;\n\n    return data;\n  } finally {\n    clearTimeout(timeoutId);\n  }\n};\n","import * as z from 'zod/mini';\n\nimport { createStorageKeySchema } from '../../../services/storage';\nimport type { WalletBookSchema } from '../legacyWalletBook.types';\n\n/**\n * The schema to store the cached wallet book data.\n */\nexport const walletBookCacheStorageKeySchema = createStorageKeySchema({\n  key: 'legacyWalletBookCache',\n  schema: z.object({\n    groups: z.record(z.string(), z.any()),\n    wallets: z.record(z.string(), z.any()),\n  }) as z.ZodMiniType<WalletBookSchema>,\n});\n","import { getCore } from '../../../client/core/getCore';\nimport type { DynamicClient } from '../../../client/types';\nimport { retryOnFail } from '../../../utils/retryOnFail';\nimport type { WalletBookSchema } from '../legacyWalletBook.types';\nimport { fetchWithTimeout } from './fetchWithTimeout';\nimport { walletBookCacheStorageKeySchema } from './walletBookCacheStorageKeySchema';\n\n/**\n * The maximum number of retry attempts.\n  * @not-instrumented\n */\nconst MAX_RETRIES = 3;\n\n/**\n * The delay between retries in milliseconds.\n */\nconst RETRY_DELAY_MS = 100;\n\n/**\n * Fetches the legacy wallet book from Dynamic's CDN endpoint.\n *\n * This function implements a two-tier fallback strategy:\n * 1. Primary: Fetch from CDN endpoint (with retries)\n * 2. Secondary: Use cached version from localStorage if available\n *\n * @param client - The Dynamic client instance.\n * @returns A promise that resolves to the wallet book data.\n * @throws If both CDN fetch and cache retrieval fail.\n  * @not-instrumented\n */\nexport const fetchLegacyWalletBook = async (\n  client: DynamicClient\n): Promise<WalletBookSchema> => {\n  const core = getCore(client);\n\n  core.logger.debug('[fetchLegacyWalletBook] Fetching wallet book...');\n\n  // Try to fetch from CDN with retry logic\n  try {\n    const walletBook = await retryOnFail({\n      delay: RETRY_DELAY_MS,\n      fn: async () => fetchWithTimeout(client),\n      maxRetries: MAX_RETRIES,\n    });\n\n    await core.storage.setItem(walletBookCacheStorageKeySchema, walletBook);\n\n    core.logger.debug(\n      '[fetchLegacyWalletBook] Successfully fetched wallet book from CDN'\n    );\n\n    return walletBook;\n  } catch (error) {\n    core.logger.debug(\n      '[fetchLegacyWalletBook] Failed to fetch from CDN, trying cache...',\n      error\n    );\n\n    // Try to get from cache\n    const cachedWalletBook = await core.storage.getItem(\n      walletBookCacheStorageKeySchema\n    );\n\n    if (cachedWalletBook) {\n      core.logger.debug('[fetchLegacyWalletBook] Using cached wallet book');\n\n      return cachedWalletBook as WalletBookSchema;\n    }\n\n    // If both CDN and cache fail, throw the original error\n    core.logger.debug(\n      '[fetchLegacyWalletBook] Failed to fetch from CDN and no cache available'\n    );\n\n    throw error;\n  }\n};\n","import type { WalletSchema } from '../legacyWalletBook.types';\n\n/**\n * Embedded wallet keys that should be filtered out from any external-wallet\n * catalogue. These wallets are not products the user \"connects\" to from the\n * wallet selection list — they are embedded sign-in methods that live behind\n * different SDK entry points.\n * @not-instrumented\n */\nexport const EMBEDDED_WALLET_KEYS = [\n  'magicemailotp',\n  'magiclink',\n  'magicsocial',\n  'turnkey',\n  'turnkeyhd',\n  'zerodev',\n  'dynamicwaas',\n  'coinbasempc',\n  'mpcvault',\n  'mpcwallet',\n];\n\nexport type ShouldFilterWalletParams = {\n  /** The wallet schema to check. */\n  wallet: WalletSchema;\n\n  /** The wallet key identifier. */\n  walletKey: string;\n};\n\n/**\n * Generic \"is this wallet eligible for an external-wallet catalogue\" check.\n * Filters out:\n *\n * 1. Embedded sign-in methods (see {@link EMBEDDED_WALLET_KEYS}).\n * 2. Wallets that only ship a browser-extension injection (`injectedConfig`)\n *    with no mobile or desktop links — these have no surface a customer\n *    catalogue UI can drive to.\n *\n * Channel-specific eligibility (WalletConnect support, in-app browser URL,\n * installation links, …) is the caller's responsibility — wrap this helper\n * with an additional check, e.g.\n * {@link shouldFilterWalletForWalletConnect}.\n *\n * @returns True if the wallet should be filtered out, false otherwise.\n * @not-instrumented\n */\nexport const shouldFilterWallet = ({\n  wallet,\n  walletKey,\n}: ShouldFilterWalletParams): boolean => {\n  if (EMBEDDED_WALLET_KEYS.includes(walletKey)) {\n    return true;\n  }\n\n  const hasInjectedConfig =\n    wallet.injectedConfig && wallet.injectedConfig.length > 0;\n  const hasMobileLinks = Boolean(\n    wallet.mobile?.androidId ||\n      wallet.mobile?.iosId ||\n      wallet.mobile?.native ||\n      wallet.mobile?.universal\n  );\n  const hasDesktopLinks = Boolean(\n    wallet.desktop?.chromeId ||\n      wallet.desktop?.edgeId ||\n      wallet.desktop?.firefoxId ||\n      wallet.desktop?.operaId ||\n      wallet.desktop?.safariId ||\n      wallet.desktop?.universal\n  );\n\n  return Boolean(hasInjectedConfig && !hasMobileLinks && !hasDesktopLinks);\n};\n","import { shouldFilterWallet } from '../../shouldFilterWallet/shouldFilterWallet';\nimport type { ShouldFilterWalletParams } from '../../shouldFilterWallet/shouldFilterWallet';\n\n/**\n * WalletConnect-specific filter. Applies the generic\n * {@link shouldFilterWallet} eligibility rules and additionally drops\n * wallets that do not advertise WalletConnect `sign_v2` support — the\n * protocol version Dynamic pairs against.\n *\n * @returns True if the wallet should be excluded from the WalletConnect\n *   catalog, false otherwise.\n * @not-instrumented\n */\nexport const shouldFilterWalletForWalletConnect = ({\n  wallet,\n  walletKey,\n}: ShouldFilterWalletParams): boolean => {\n  if (shouldFilterWallet({ wallet, walletKey })) {\n    return true;\n  }\n\n  return !wallet.walletConnect?.sdks.includes('sign_v2');\n};\n","import { DYNAMIC_ICONIC_SPRITE_URL } from '../../../constants';\n\ntype GetSpriteUrlParams = {\n  spriteId: string;\n};\n\n/**\n * Gets the sprite URL for a given sprite ID.\n *\n * @param params.spriteId - The sprite identifier from the wallet book.\n * @returns The full URL to the sprite icon\n  * @not-instrumented\n */\nexport const getSpriteUrl = ({ spriteId }: GetSpriteUrlParams): string =>\n  `${DYNAMIC_ICONIC_SPRITE_URL}#${spriteId}`;\n","import { getSpriteUrl } from '../../getSpriteUrl';\nimport type { WalletBookSchema } from '../../legacyWalletBook.types';\nimport type { WalletConnectCatalogGroup } from '../getWalletConnectCatalog.types';\n\ntype TransformGroupParams = {\n  group: WalletBookSchema['groups'][string];\n};\n\n/**\n * Transforms a wallet group schema into a WalletConnect catalog group.\n  * @not-instrumented\n */\nexport const transformGroup = ({\n  group,\n}: TransformGroupParams): WalletConnectCatalogGroup => {\n  const spriteId = group.brand?.spriteId ?? '';\n\n  return {\n    key: group.key,\n    name: group.name,\n    primaryColor: group.brand?.primaryColor,\n    spriteUrl: spriteId ? getSpriteUrl({ spriteId }) : '',\n  };\n};\n","import type { Chain } from '../../modules/chain';\nimport { CHAINS_INFO_MAP } from '../../modules/wallets/constants';\n\ntype GetChainFromWalletBookIdentifierParams = {\n  identifier: string;\n};\n\n/**\n * Resolves a wallet-book chain identifier (as found in\n * `injectedConfig[].chain` or as an alias embedded in a wallet key) to a\n * {@link Chain}. Looks up by `apiChainName` first, then by any\n * `legacyWalletBookAliases` declared on the corresponding `CHAINS_INFO_MAP`\n * entry.\n *\n * Returns `undefined` when the identifier doesn't match any known chain,\n * letting the caller pick its own fallback (e.g. defaulting to EVM, or\n * trying a different lookup strategy).\n *\n * Centralised here rather than in `legacyWalletBook` so all chain naming\n * knowledge stays alongside `CHAINS_INFO_MAP`.\n * @not-instrumented\n */\nexport const getChainFromWalletBookIdentifier = ({\n  identifier,\n}: GetChainFromWalletBookIdentifierParams): Chain | undefined => {\n  const normalised = identifier.toLowerCase();\n  const chains = Object.keys(CHAINS_INFO_MAP) as Chain[];\n\n  return chains.find((chain) => {\n    const info = CHAINS_INFO_MAP[chain];\n\n    return (\n      info.apiChainName === normalised ||\n      info.legacyWalletBookAliases?.includes(normalised) === true\n    );\n  });\n};\n","import type { Chain } from '../../../chain';\nimport { getChainFromVerifiedCredentialChain } from '../../../../utils/getChainFromVerifiedCredentialChain';\nimport { getChainFromWalletBookIdentifier } from '../../../../utils/getChainFromWalletBookIdentifier';\nimport { CHAINS_INFO_MAP } from '../../../wallets/constants';\nimport type { WalletSchema } from '../../legacyWalletBook.types';\n\ntype ExtractChainPrefixParams = {\n  chainIdentifier: string;\n};\n\n/**\n * Extracts the chain prefix from a chain identifier string.\n * For example, \"eip155:1\" -> \"eip155\", \"solana:...\" -> \"solana\"\n *\n * Exported so {@link getChainsFromWalletSchema} can apply the same\n * parsing to its multi-chain pass without duplicating the logic.\n * @not-instrumented\n */\nexport const extractChainPrefix = ({\n  chainIdentifier,\n}: ExtractChainPrefixParams): string => {\n  const colonIndex = chainIdentifier.indexOf(':');\n\n  if (colonIndex === -1) {\n    return chainIdentifier;\n  }\n\n  return chainIdentifier.substring(0, colonIndex);\n};\n\ntype GetChainFromWalletKeyParams = {\n  walletKey: string;\n};\n\n/**\n * Attempts to extract the chain from a wallet key by looking for embedded\n * chain identifiers (apiChainName + legacyWalletBookAliases from CHAINS_INFO_MAP).\n *\n * Derives patterns dynamically so adding a chain in `CHAINS_INFO_MAP`\n * picks it up here — no parallel hardcoded list.\n *\n * @param params.walletKey - The wallet key identifier.\n * @returns The chain type if found, undefined otherwise.\n */\n// eslint-disable-next-line custom-rules/one-function-per-file\nconst getChainFromWalletKey = ({\n  walletKey,\n}: GetChainFromWalletKeyParams): Chain | undefined => {\n  const lowerKey = walletKey.toLowerCase();\n  const chains = Object.keys(CHAINS_INFO_MAP) as Chain[];\n\n  for (const chain of chains) {\n    const info = CHAINS_INFO_MAP[chain];\n    const patterns = [info.apiChainName, ...(info.legacyWalletBookAliases ?? [])];\n\n    if (patterns.some((pattern) => lowerKey.includes(pattern))) {\n      return chain;\n    }\n  }\n\n  return undefined;\n};\n\ntype GetChainFromWalletSchemaParams = {\n  wallet: WalletSchema;\n  walletKey?: string;\n};\n\n/**\n * Gets the chain from a wallet book entry.\n * Checks injectedConfig first, then falls back to the chains array, then the wallet key.\n * If no chain can be determined, defaults to EVM.\n *\n * @param params.wallet - The wallet schema from the wallet book.\n * @param params.walletKey - The wallet key identifier (optional, used as last resort fallback).\n * @returns The chain type, defaults to EVM if no chain can be determined.\n  * @not-instrumented\n */\n// eslint-disable-next-line custom-rules/one-function-per-file\nexport const getChainFromWalletSchema = ({\n  wallet,\n  walletKey,\n}: GetChainFromWalletSchemaParams): Chain => {\n  // First, check injectedConfig for the chain field\n  if (wallet.injectedConfig && wallet.injectedConfig.length > 0) {\n    const injectedChain = wallet.injectedConfig[0].chain;\n\n    if (injectedChain) {\n      const chain = getChainFromWalletBookIdentifier({\n        identifier: injectedChain,\n      });\n\n      if (chain) {\n        return chain;\n      }\n    }\n  }\n\n  // Fall back to checking the chains array\n  if (wallet.chains && wallet.chains.length > 0) {\n    const firstChain = wallet.chains[0];\n    const chainPrefix = extractChainPrefix({ chainIdentifier: firstChain });\n\n    try {\n      return getChainFromVerifiedCredentialChain(chainPrefix);\n    } catch {\n      // If the chain prefix is not recognized, fall back to wallet key check\n    }\n  }\n\n  // Last resort: try to extract chain from wallet key\n  if (walletKey) {\n    const chainFromKey = getChainFromWalletKey({ walletKey });\n\n    if (chainFromKey) {\n      return chainFromKey;\n    }\n  }\n\n  // Default to EVM if no chain can be determined\n  return 'EVM';\n};\n","import { getSpriteUrl } from '../../getSpriteUrl';\nimport type { WalletBookSchema } from '../../legacyWalletBook.types';\nimport { getChainFromWalletSchema } from '../getChainFromWalletSchema';\nimport type { WalletConnectCatalogWallet } from '../getWalletConnectCatalog.types';\n\ntype TransformWalletParams = {\n  wallet: WalletBookSchema['wallets'][string];\n  walletKey: string;\n};\n\n/**\n * Transforms a wallet schema into a WalletConnect catalog wallet entry.\n  * @not-instrumented\n */\nexport const transformWallet = ({\n  wallet,\n  walletKey,\n}: TransformWalletParams): WalletConnectCatalogWallet => {\n  const spriteId = wallet.brand?.spriteId ?? '';\n\n  const androidId = wallet.mobile?.androidId;\n  const iosId = wallet.mobile?.iosId;\n\n  return {\n    chain: getChainFromWalletSchema({ wallet, walletKey }),\n    deeplinks: {\n      native: wallet.mobile?.native,\n      universal: wallet.mobile?.universal,\n    },\n    downloadLinks: {\n      androidUrl: androidId\n        ? `https://play.google.com/store/apps/details?id=${androidId}`\n        : undefined,\n      iosUrl: iosId ? `https://apps.apple.com/app/${iosId}` : undefined,\n    },\n    groupId: wallet.group,\n    name: wallet.name,\n    primaryColor: wallet.brand?.primaryColor,\n    spriteUrl: spriteId ? getSpriteUrl({ spriteId }) : '',\n  };\n};\n","import type { WalletBookSchema } from '../../legacyWalletBook.types';\nimport type {\n  WalletConnectCatalog,\n  WalletConnectCatalogGroup,\n  WalletConnectCatalogWallet,\n} from '../getWalletConnectCatalog.types';\nimport { shouldFilterWalletForWalletConnect } from '../shouldFilterWalletForWalletConnect/shouldFilterWalletForWalletConnect';\nimport { transformGroup } from '../transformGroup';\nimport { transformWallet } from '../transformWallet';\n\ntype TransformWalletBookParams = {\n  walletBook: WalletBookSchema;\n};\n\n/**\n * Transforms the legacy wallet book into a WalletConnect catalog structure.\n * Filters out embedded wallets and injected-only wallets.\n  * @not-instrumented\n */\nexport const transformWalletBook = ({\n  walletBook,\n}: TransformWalletBookParams): WalletConnectCatalog => {\n  const groups: Record<string, WalletConnectCatalogGroup> = {};\n\n  for (const [groupKey, group] of Object.entries(walletBook.groups)) {\n    groups[groupKey] = transformGroup({ group });\n  }\n\n  const wallets: Record<string, WalletConnectCatalogWallet> = {};\n\n  for (const [walletKey, wallet] of Object.entries(walletBook.wallets)) {\n    if (shouldFilterWalletForWalletConnect({ wallet, walletKey })) {\n      continue;\n    }\n\n    wallets[walletKey] = transformWallet({ wallet, walletKey });\n  }\n\n  return { groups, wallets };\n};\n","import { getDefaultClient } from '../../../client/defaultClient';\nimport { fetchLegacyWalletBook } from '../fetchLegacyWalletBook';\nimport type { WalletConnectCatalog } from './getWalletConnectCatalog.types';\nimport { transformWalletBook } from './transformWalletBook';\n\n/**\n * Retrieves the WalletConnect catalog from Dynamic's wallet book.\n *\n * This function fetches the wallet book and returns a WalletConnect catalog structure\n * that can be used for displaying wallet information and performing deep links for mobile wallet connections.\n *\n * @param [client] - The Dynamic client instance. Only required when using multiple Dynamic clients.\n * @returns A promise that resolves to the WalletConnect catalog containing groups and wallets.\n * @throws If unable to fetch the wallet book from the API (when both CDN fetch and cache retrieval fail).\n  * @not-instrumented\n */\nexport const getWalletConnectCatalog = async (\n  client = getDefaultClient()\n): Promise<WalletConnectCatalog> => {\n  const walletBook = await fetchLegacyWalletBook(client);\n\n  return transformWalletBook({ walletBook });\n};\n","import type { WalletProviderData } from '../../wallets/walletProvider/walletProvider.types';\n\ntype MatchWalletProvidersToCatalogGroupParams = {\n  catalogGroupKey: string;\n  catalogGroupName?: string;\n  walletProviders: WalletProviderData[];\n};\n\nconst normalize = (value: string): string =>\n  value.toLowerCase().replace(/\\s+/g, '').replace(/wallet/g, '');\n\n/**\n * Returns the wallet providers that belong to the same wallet group as the\n * given WalletConnect catalog entry. Useful for de-duplicating \"installed\"\n * vs \"available via WalletConnect\" wallets when rendering a combined list.\n *\n * Matching is done on normalized identifiers — lowercased, whitespace removed,\n * and the literal substring \"wallet\" stripped — so that variations like:\n *   - catalog key `\"trust\"` + catalog name `\"Trust Wallet\"`\n *   - provider `groupKey: \"trustwallet\"` + `displayName: \"Trust Wallet\"`\n * collapse into a single match.\n *\n * @param params.catalogGroupKey - Key of the catalog group (e.g. `\"metamask\"`).\n * @param [params.catalogGroupName] - Optional display name (e.g. `\"Trust Wallet\"`); matched as a fallback when the key is opaque.\n * @param params.walletProviders - Currently available wallet providers (from `getAvailableWalletProvidersData`).\n * @returns The subset of `walletProviders` that match the catalog group.\n * @not-instrumented\n */\nexport const matchWalletProvidersToCatalogGroup = ({\n  catalogGroupKey,\n  catalogGroupName,\n  walletProviders,\n}: MatchWalletProvidersToCatalogGroupParams): WalletProviderData[] => {\n  const targets = new Set<string>([normalize(catalogGroupKey)]);\n  if (catalogGroupName) targets.add(normalize(catalogGroupName));\n\n  return walletProviders.filter((provider) => {\n    const candidates = [\n      normalize(provider.groupKey),\n      normalize(provider.metadata.displayName),\n    ];\n    return candidates.some((candidate) => targets.has(candidate));\n  });\n};\n","import type { WalletProviderData } from '../../../wallets/walletProvider/walletProvider.types';\nimport type { WalletConnectCatalog } from '../../getWalletConnectCatalog/getWalletConnectCatalog.types';\nimport { matchWalletProvidersToCatalogGroup } from '../../matchWalletProvidersToCatalogGroup';\n\ntype CollectInstalledGroupIdsParams = {\n  catalog: WalletConnectCatalog;\n  walletProviders: WalletProviderData[];\n};\n\n/**\n * Scans the catalog and returns the set of group identifiers for which at\n * least one installed wallet provider matches.\n *\n * Walks the catalog twice on purpose:\n * - First through `wallets`, to cover wallets that point to a `groupId`\n *   with no matching entry in `groups` (we fall back to the wallet's own\n *   name for matching in that case).\n * - Then through `groups`, to catch orphan group entries that have no\n *   wallet referencing them.\n *\n * The check is skipped for any group already known to be installed, so a\n * multi-chain wallet (same `groupId` across EVM + SOL entries) only runs\n * the match once.\n *\n * @not-instrumented\n */\nexport const collectInstalledGroupIds = ({\n  catalog,\n  walletProviders,\n}: CollectInstalledGroupIdsParams): Set<string> => {\n  const installedGroupIds = new Set<string>();\n\n  // First pass: iterate wallets so we can use each wallet's own `name` as a\n  // fallback when its group has no metadata entry in `catalog.groups`.\n  for (const [walletKey, wallet] of Object.entries(catalog.wallets)) {\n    const groupId = wallet.groupId || walletKey;\n    if (installedGroupIds.has(groupId)) continue;\n\n    const groupName = catalog.groups[groupId]?.name || wallet.name;\n\n    const matches = matchWalletProvidersToCatalogGroup({\n      catalogGroupKey: groupId,\n      catalogGroupName: groupName,\n      walletProviders,\n    });\n\n    if (matches.length > 0) installedGroupIds.add(groupId);\n  }\n\n  // Second pass: pick up groups that exist in `catalog.groups` but are not\n  // referenced by any wallet (e.g. brand-only entries).\n  for (const [groupKey, group] of Object.entries(catalog.groups)) {\n    if (installedGroupIds.has(groupKey)) continue;\n\n    const matches = matchWalletProvidersToCatalogGroup({\n      catalogGroupKey: groupKey,\n      catalogGroupName: group.name,\n      walletProviders,\n    });\n\n    if (matches.length > 0) installedGroupIds.add(groupKey);\n  }\n\n  return installedGroupIds;\n};\n","import type { WalletProviderData } from '../../wallets/walletProvider/walletProvider.types';\nimport type { WalletConnectCatalog } from '../getWalletConnectCatalog/getWalletConnectCatalog.types';\nimport { collectInstalledGroupIds } from './collectInstalledGroupIds';\n\ntype ExcludeInstalledFromCatalogParams = {\n  catalog: WalletConnectCatalog;\n  walletProviders: WalletProviderData[];\n};\n\n/**\n * Returns a new WalletConnect catalog with the wallets and groups that the\n * user already has installed removed.\n *\n * Useful when rendering a combined wallet list (installed + WalletConnect\n * catalog) where each wallet should appear exactly once: installed wallets\n * win and the corresponding catalog entries get hidden.\n *\n * Matching is delegated to {@link collectInstalledGroupIds}, so a single\n * installed provider removes every wallet that shares its group — e.g. an\n * installed MetaMask hides both the EVM and SOL catalog entries.\n *\n * The original catalog object is not mutated.\n *\n * @param params.catalog - The full WalletConnect catalog (typically from `getWalletConnectCatalog`).\n * @param params.walletProviders - Currently available wallet providers.\n * @returns A new catalog with only the wallets and groups the user does not have installed.\n * @not-instrumented\n */\nexport const excludeInstalledFromCatalog = ({\n  catalog,\n  walletProviders,\n}: ExcludeInstalledFromCatalogParams): WalletConnectCatalog => {\n  // Step 1: figure out which catalog groups the user already has installed.\n  // We compute this up front so filtering wallets and groups below is a\n  // simple set lookup per entry.\n  const installedGroupIds = collectInstalledGroupIds({\n    catalog,\n    walletProviders,\n  });\n\n  // Step 2: keep only wallets whose effective group id is not installed.\n  // Wallets without an explicit `groupId` are treated as their own group,\n  // which mirrors how the catalog itself associates wallets to groups.\n  const wallets: WalletConnectCatalog['wallets'] = {};\n  for (const [walletKey, wallet] of Object.entries(catalog.wallets)) {\n    const groupId = wallet.groupId || walletKey;\n    if (installedGroupIds.has(groupId)) continue;\n    wallets[walletKey] = wallet;\n  }\n\n  // Step 3: keep only group metadata entries that are not installed. This\n  // prevents the caller from rendering an empty/orphan group with no\n  // wallets behind it.\n  const groups: WalletConnectCatalog['groups'] = {};\n  for (const [groupKey, group] of Object.entries(catalog.groups)) {\n    if (installedGroupIds.has(groupKey)) continue;\n    groups[groupKey] = group;\n  }\n\n  return { groups, wallets };\n};\n","import type { Chain } from '../../../chain';\nimport { CHAINS_INFO_MAP } from '../../constants';\n\ntype ExtractChainFromNormalizedNameParams = {\n  normalizedWalletNameWithChain: string;\n};\n\n/**\n * Extracts the chain from a normalized wallet name with chain suffix.\n 