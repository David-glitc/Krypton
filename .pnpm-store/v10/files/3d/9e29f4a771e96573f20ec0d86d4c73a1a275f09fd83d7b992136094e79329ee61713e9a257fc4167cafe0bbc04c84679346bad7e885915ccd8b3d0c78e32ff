rtDefined(\n    appNativeLink,\n    'metadata.nativeLink must be set on the Dynamic client to use signInWithSocialPopUp'\n  );\n\n  await core.initTrack.waitForAll();\n\n  const providerType = provider as ProviderEnum;\n\n  const { url, state, codeVerifier } = await buildOAuthUrl(core, providerType);\n\n  await apiClient.initAuth({\n    environmentId: core.environmentId,\n    oauthInitAuthRequest: {\n      redirectUrl: appNativeLink,\n      state,\n    },\n    providerType,\n  });\n\n  // Persist state so processSocialCallback can validate it after the callback\n  await core.storage.setItem(redirectStateStorageKeySchema, {\n    codeVerifier,\n    provider: providerType,\n    state,\n  });\n\n  // Host app can plug in their own auth session (e.g. expo-web-browser) via\n  // coreConfig.openAuthSession; otherwise fall back to the inlined default.\n  const openSession = core.openAuthSession ?? openDefaultAuthSession;\n\n  try {\n    const result = await openSession({\n      authUrl: url.toString(),\n      redirectUrl: appNativeLink,\n    });\n\n    if (result.type === 'cancel') {\n      throw new UserCancelledSocialPopUpError();\n    }\n\n    const callbackUrl = new URL(result.url);\n    const expectedUrl = new URL(appNativeLink);\n\n    // Guard against open-redirect / compromised-session attacks: the callback\n    // URL returned by the in-app browser MUST match the redirect URL we gave\n    // to the provider. Compare protocol + host so http(s) origins and custom\n    // schemes (e.g. `expodemo://`) are handled consistently.\n    const callbackOrigin = `${callbackUrl.protocol}//${callbackUrl.host}`;\n    const expectedOrigin = `${expectedUrl.protocol}//${expectedUrl.host}`;\n\n    if (callbackOrigin !== expectedOrigin) {\n      throw new InvalidSocialCallbackOriginError({\n        actualOrigin: callbackOrigin,\n        expectedOrigin,\n      });\n    }\n\n    return await processSocialCallback({ url: callbackUrl }, client);\n  } catch (error) {\n    // Ensure no stal