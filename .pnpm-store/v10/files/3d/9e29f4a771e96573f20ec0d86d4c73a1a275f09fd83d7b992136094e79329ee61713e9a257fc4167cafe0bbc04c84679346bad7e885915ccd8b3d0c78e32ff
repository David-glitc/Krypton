arams = {\n  wallet: WalletBookSchema['wallets'][string];\n};\n\n/**\n * Returns the wallet's in-app browser URL template, preferring the v2\n * field. `inAppBrowser` is deprecated but some wallet book entries\n * still carry only the v1 value, so it acts as a fallback. Trailing\n * `?? undefined` collapses the schema's `string | null` typing down to\n * the `string | undefined` return contract.\n *\n * @param params.wallet - The wallet book wallet entry.\n * @returns The in-app browser URL, or `undefined` if neither field is set.\n * @not-instrumented\n */\nexport const getInAppBrowserUrl = ({\n  wallet,\n}: GetInAppBrowserUrlParams): string | undefined =>\n  wallet.mobile?.inAppBrowserV2 ?? wallet.mobile?.inAppBrowser ?? undefined; // NOSONAR\n","import { getChainFromWalletSchema } from '../../legacyWalletBook/getWalletConnectCatalog/getChainFromWalletSchema/getChainFromWalletSchema';\nimport type { WalletBookSchema } from '../../legacyWalletBook/legacyWalletBook.types';\nimport { shouldFilterWallet } from '../../legacyWalletBook/shouldFilterWallet/shouldFilterWallet';\nimport type { ConnectionOptionForWalletOption } from '../groupOptionsByWalletOption/groupOptionsByWalletOption';\nimport { resolveWalletBookWalletOptionKey } from '../resolveWalletBookWalletOptionKey/resolveWalletBookWalletOptionKey';\nimport { getInAppBrowserUrl } from './getInAppBrowserUrl/getInAppBrowserUrl';\n\ntype BuildInAppBrowserOptionsParams = {\n  walletBook: WalletBookSchema;\n};\n\n/**\n * Builds the `inAppBrowser` catalogue options from the wallet book. A wallet\n * qualifies when it exposes a mobile in-app-browser URL — typically a\n * `cb_url={{encodedDappURI}}`-style template the customer fills in with the\n * current page URL before opening.\n *\n * Reuses the generic `shouldFilterWallet` rules — embedded sign-in methods\n * and injected-only wallets are dropped — so the catalogue's notion of\n * \"external wallet\" stays consistent across option types.\n *\n * @param params.walletBook - The fetched wallet book.\n * @returns Tagged `inAppBrowser` options paired with their wallet option keys.\n * @not-instrumented\n */\nexport const buildInAppBrowserOptions = ({\n  walletBook,\n}: BuildInAppBrowserOptionsParams): ConnectionOptionForWalletOption[] => {\n  const result: ConnectionOptionForWalletOption[] = [];\n\n  for (const [walletKey, wallet] of Object.entries(walletBook.wallets)) {\n    if (shouldFilterWallet({ wallet, walletKey })) {\n      continue;\n    }\n\n    const url = getInAppBrowserUrl({ wallet });\n\n    if (!url) {\n      continue;\n    }\n\n    result.push({\n      option: {\n        chain: getChainFromWalletSchema({ wallet, walletKey }),\n        type: 'inAppBrowser',\n        url,\n      },\n      walletOptionKey: resolveWalletBookWalletOptionKey({ wallet, walletKey }),\n    });\n  }\n\n  return result;\n};\n","import type { WalletSchema } from '../../legacyWalletBook/legacyWalletBook.types';\nimport type { InstallationUrls } from '../walletOptionsCatalogue.types';\n\nconst PLAY_STORE_URL_TEMPLATE =\n  'https://play.google.com/store/apps/details?id=';\nconst APP_STORE_URL_TEMPLATE = 'https://apps.apple.com/app/';\nconst CHROME_WEB_STORE_URL_TEMPLATE =\n  'https://chrome.google.com/webstore/detail/';\nconst FIREFOX_ADDONS_URL_TEMPLATE =\n  'https://addons.mozilla.org/firefox/addon/';\nconst EDGE_ADDONS_URL_TEMPLATE =\n  'https://microsoftedge.microsoft.com/addons/detail/';\n\ntype BuildInstallationUrlsParams = {\n  wallet: WalletSchema;\n};\n\n/**\n * Builds the install/download URL bag for a wallet book entry. Returns the\n * concrete URLs assembled from each store's ID field — Play Store, App\n * Store, Chrome Web Store, Firefox Add-ons, Edge Add-ons — plus the wallet's\n * own `desktop.universal` / `desktop.native` URLs when set.\n *\n * Fields the wallet book does not carry are left undefined; callers should\n * skip emitting an installation option for a wallet whose URL bag is empty.\n *\n * @param params.wallet - The wallet book entry.\n * @returns The URL bag, omitting fields the wallet does not provide.\n * @not-instrumented\n */\nexport const buildInstallationUrls = ({\n  wallet,\n}: BuildInstallationUrlsParams): InstallationUrls => {\n  const androidId = wallet.mobile?.androidId;\n  const iosId = wallet.mobile?.iosId;\n  const chromeId = wallet.desktop?.chromeId;\n  const firefoxId = wallet.desktop?.firefoxId;\n  const edgeId = wallet.desktop?.edgeId;\n  const native = wallet.desktop?.universal ?? wallet.desktop?.native;\n\n  return {\n    android: androidId ? `${PLAY_STORE_URL_TEMPLATE}${androidId}` : undefined,\n    chrome: chromeId\n      ? `${CHROME_WEB_STORE_URL_TEMPLATE}${chromeId}`\n      : undefined,\n    edge: edgeId ? `${EDGE_ADDONS_URL_TEMPLATE}${edgeId}` : undefined,\n    firefox: firefoxId\n      ? `${FIREFOX_ADDONS_URL_TEMPLATE}${firefoxId}`\n      : undefined,\n    ios: iosId ? `${APP_STORE_URL_TEMPLATE}${iosId}` : undefined,\n    native: native || undefined,\n  };\n};\n","import type { WalletBookSchema } from '../../legacyWalletBook/legacyWalletBook.types';\nimport { shouldFilterWallet } from '../../legacyWalletBook/shouldFilterWallet/shouldFilterWallet';\nimport { buildInstallationUrls } from '../buildInstallationUrls/buildInstallationUrls';\nimport { resolveWalletBookWalletOptionKey } from '../resolveWalletBookWalletOptionKey/resolveWalletBookWalletOptionKey';\nimport type { InstallationUrls } from '../walletOptionsCatalogue.types';\n\ntype HasAnyInstallationUrlParams = {\n  urls: InstallationUrls;\n};\n\n/**\n * `buildInstallationUrls` always returns an object, but it can be fully\n * `undefined`-valued when the wallet book entry has no installable surface.\n * Skip those wallets — emitting an empty URL bag helps nobody.\n */\nconst hasAnyInstallationUrl = ({ urls }: HasAnyInstallationUrlParams): boolean =>\n  Object.values(urls).some(Boolean);\n\ntype BuildInstallationUrlsByWalletOptionKeyParams = {\n  walletBook: WalletBookSchema;\n};\n\n/**\n * Collects install / download URLs for every wallet book entry that has\n * at least one installable surface, keyed by the wallet option key the\n * wallet groups under. The catalogue assembly step merges this map into\n * the per-key wallet option shell so `WalletOption.installationUrls` is\n * populated alongside (or instead of) `connectionOptions`.\n *\n * First-seen URLs win when multiple wallet book entries resolve to the\n * same wallet option key — wallet book authors put the most accurate\n * install links on the canonical entry, so the first-seen one is the\n * right pick.\n *\n * Reuses the generic `shouldFilterWallet` rules so embedded wallets do\n * not appear here either — they're not user-installable products.\n *\n * @param params.walletBook - The fetched wallet book.\n * @returns A map from wallet option key to its install URL bag.\n * @not-instrumented\n */\nexport const buildInstallationUrlsByWalletOptionKey = ({\n  walletBook,\n}: BuildInstallationUrlsByWalletOptionKeyParams): Map<\n  string,\n  InstallationUrls\n> => {\n  const map = new Map<string, InstallationUrls>();\n\n  for (const [walletKey, wallet] of Object.entries(walletBook.wallets)) {\n    if (shouldFilterWallet({ wallet, walletKey })) {\n      continue;\n    }\n\n    const urls = buildInstallationUrls({ wallet });\n\n    if (!hasAnyInstallationUrl({ urls })) {\n      continue;\n    }\n\n    const walletOptionKey = resolveWalletBookWalletOptionKey({\n      wallet,\n      walletKey,\n    });\n\n    if (!map.has(walletOptionKey)) {\n      map.set(walletOptionKey, urls);\n    }\n  }\n\n  return map;\n};\n","import type { WalletSchema } from '../legacyWalletBook.types';\n\ntype HasUsableDeeplinkParams = {\n  wallet: WalletSchema;\n};\n\n/**\n * Whether a wallet book entry exposes at least one mobile deeplink the\n * catalogue can drive — either a native scheme (`metamask://`) or a\n * universal link (`https://metamask.app.link`). Used by the URI-deeplink\n * builders (`buildWalletConnectOptions`, `buildMetaMaskSdkUriOptions`)\n * to skip wallets that have no app to launch.\n *\n * @param params.wallet - The wallet schema from the wallet book.\n * @returns True when the wallet has a native or universal mobile link.\n * @not-instrumented\n */\nexport const hasUsableDeeplink = ({\n  wallet,\n}: HasUsableDeeplinkParams): boolean =>\n  Boolean(wallet.mobile?.native || wallet.mobile?.universal);\n","import type { Chain } from '../../chain';\nimport { hasUsableDeeplink } from '../../legacyWalletBook/hasUsableDeeplink/hasUsableDeeplink';\nimport type { WalletBookSchema } from '../../legacyWalletBook/legacyWalletBook.types';\nimport { shouldFilterWallet } from '../../legacyWalletBook/shouldFilterWallet/shouldFilterWallet';\nimport type { ConnectionOptionForWalletOption } from '../groupOptionsByWalletOption/groupOptionsByWalletOption';\nimport { resolveWalletBookWalletOptionKey } from '../resolveWalletBookWalletOptionKey/resolveWalletBookWalletOptionKey';\n\n/**\n * Wallet option key the MetaMask SDK URI extension targets.\n */\nconst METAMASK_WALLET_OPTION_KEY = 'metamask';\n\n/**\n * Chains the MetaMask SDK URI pairing supports.\n *\n * Unlike WalletConnect — whose per-wallet chain support is read from the\n * wallet book — the MetaMask SDK URI is a single Dynamic integration whose\n * chain coverage is defined by which `connectWithMetaMaskUri<Chain>`\n * primitives the SDK ships (EVM + SOL). The MetaMask wallet-book entry only\n * advertises its EVM (`eip155`) chains, so deriving the chain from the book\n * would never surface the Solana pairing; the SDK's own capabilities are\n * listed explicitly instead.\n */\nconst METAMASK_SDK_URI_SUPPORTED_CHAINS: readonly Chain[] = ['EVM', 'SOL'];\n\ntype BuildMetaMaskSdkUriOptionsParams = {\n  walletBook: WalletBookSchema;\n};\n\n/**\n * Builds the `metamaskSdkUri`-discriminator catalogue options from a\n * fetched wallet book. The MetaMask SDK URI extension only targets the\n * MetaMask wallet, so the builder iterates the book looking for the\n * entry whose resolved wallet option key is `'metamask'`.\n *\n * Applies the generic `shouldFilterWallet` rules (drops embedded keys +\n * injected-only-without-links entries). Crucially does NOT require WC\n * `sign_v2` support — MetaMask SDK URI is a different protocol from\n * WalletConnect, so the WC-specific filter does not apply here.\n *\n * Emits one `metamaskSdkUri` option per chain the MetaMask SDK URI pairing\n * supports (see {@link METAMASK_SDK_URI_SUPPORTED_CHAINS}) so the picker can\n * offer both the EVM and Solana pairings for the single MetaMask entry.\n *\n * @param params.walletBook - The fetched wallet book.\n * @returns Tagged `metamaskSdkUri` options for MetaMask if eligible, otherwise an empty array.\n * @not-instrumented\n */\nexport const buildMetaMaskSdkUriOptions = ({\n  walletBook,\n}: BuildMetaMaskSdkUriOptionsParams): ConnectionOptionForWalletOption[] => {\n  for (const [walletKey, wallet] of Object.entries(walletBook.wallets)) {\n    const walletOptionKey = resolveWalletBookWalletOptionKey({\n      wallet,\n      walletKey,\n    });\n\n    if (walletOptionKey !== METAMASK_WALLET_OPTION_KEY) {\n      continue;\n    }\n\n    if (shouldFilterWallet({ wallet, walletKey })) {\n      continue;\n    }\n\n    if (!hasUsableDeeplink({ wallet })) {\n      continue;\n    }\n\n    const deeplinks = {\n      native: wallet.mobile?.native,\n      universal: wallet.mobile?.universal,\n    };\n\n    // One option per supported chain so the wallet picker can offer (and\n    // chain-switch between) MetaMask's EVM and Solana URI pairings.\n    return METAMASK_SDK_URI_SUPPORTED_CHAINS.map((chain) => ({\n      option: {\n        chain,\n        deeplinks,\n        type: 'metamaskSdkUri',\n      },\n      walletOptionKey,\n    }));\n  }\n\n  return [];\n};\n","import { getChainFromVerifiedCredentialChain } from '../../../../utils/getChainFromVerifiedCredentialChain';\nimport { getChainFromWalletBookIdentifier } from '../../../../utils/getChainFromWalletBookIdentifier';\nimport type { Chain } from '../../../chain';\nimport type { WalletSchema } from '../../legacyWalletBook.types';\nimport {\n  extractChainPrefix,\n  getChainFromWalletSchema,\n} from '../getChainFromWalletSchema/getChainFromWalletSchema';\n\ntype GetChainsFromWalletSchemaParams = {\n  wallet: WalletSchema;\n  walletKey?: string;\n};\n\n/**\n * Returns every chain a wallet book entry advertises support for —\n * deduped, in `injectedConfig` order, then `chains` order. Used by the\n * catalogue's WalletConnect builder so a multi-chain wallet (e.g. Trust\n * supports EVM + SOL) gets one option per chain rather than one option\n * for whichever chain `getChainFromWalletSchema` happened to pick first.\n *\n * Falls back to {@link getChainFromWalletSchema}'s single-result behavior\n * (`['EVM']` default) when neither field is populated, so the helper\n * never returns an empty array — every eligible wallet emits at least\n * one option.\n *\n * @param params.wallet - The wallet schema from the wallet book.\n * @param [params.walletKey] - The wallet key identifier (used as last-resort fallback).\n * @returns Ordered, deduped array of Chains.\n * @not-instrumented\n */\nexport const getChainsFromWalletSchema = ({\n  wallet,\n  walletKey,\n}: GetChainsFromWalletSchemaParams): Chain[] => {\n  // Set keeps insertion order, so collect → toArray preserves the\n  // injectedConfig-first, chains-second emission order without a parallel\n  // dedupe array.\n  const chains = new Set<Chain>();\n\n  for (const entry of wallet.injectedConfig ?? []) {\n    if (!entry.chain) continue;\n\n    const chain = getChainFromWalletBookIdentifier({ identifier: entry.chain });\n\n    if (chain) chains.add(chain);\n  }\n\n  for (const identifier of wallet.chains ?? []) {\n    const prefix = extractChainPrefix({ chainIdentifier: identifier });\n\n    try {\n      const chain = getChainFromVerifiedCredentialChain(prefix);\n      chains.add(chain);\n    } catch {\n      // Unknown prefix — skip.\n    }\n  }\n\n  if (chains.size === 0) {\n    const chain = getChainFromWalletSchema({ wallet, walletKey });\n    chains.add(chain);\n  }\n\n  return Array.from(chains);\n};\n","import type { Chain } from '../../chain';\nimport { getChainsFromWalletSchema } from '../../legacyWalletBook/getWalletConnectCatalog/getChainsFromWalletSchema/getChainsFromWalletSchema';\nimport { shouldFilterWalletForWalletConnect } from '../../legacyWalletBook/getWalletConnectCatalog/shouldFilterWalletForWalletConnect/shouldFilterWalletForWalletConnect';\nimport { hasUsableDeeplink } from '../../legacyWalletBook/hasUsableDeeplink/hasUsableDeeplink';\nimport type { WalletBookSchema } from '../../legacyWalletBook/legacyWalletBook.types';\nimport type { ConnectionOptionForWalletOption } from '../groupOptionsByWalletOption/groupOptionsByWalletOption';\nimport { resolveWalletBookWalletOptionKey } from '../resolveWalletBookWalletOptionKey/resolveWalletBookWalletOptionKey';\n\n/**\n * Chains Dynamic ships a WalletConnect extension for. Anything else a\n * wallet book entry advertises (Cosmos, BTC, …) gets filtered out — the\n * catalogue should not surface a chain the SDK has no `connectWithWalletConnect<Chain>`\n * primitive for.\n */\nconst WALLETCONNECT_SUPPORTED_CHAINS: ReadonlySet<Chain> = new Set([\n  'EVM',\n  'SOL',\n]);\n\ntype BuildWalletConnectOptionsParams = {\n  walletBook: WalletBookSchema;\n};\n\n/**\n * Builds the `walletConnect`-discriminator catalogue options from a fetched\n * wallet book. Applies the WalletConnect-specific eligibility filter\n * (`shouldFilterWalletForWalletConnect`) so embedded wallets and entries\n * without `sign_v2` support are excluded — same surface as\n * `getWalletConnectCatalog`.\n *\n * Skips the MetaMask wallet entry: MetaMask is steered to its own URI\n * connection extension via `buildMetaMaskSdkUriOptions`. Keeping the two\n * builders separate means each protocol owns its own eligibility rules\n * (WC needs `sign_v2`; MM SDK URI does not), so excluding one\n * discriminator via `excludedConnectionOptionTypes` doesn't accidentally\n * gate the other.\n *\n * @param params.walletBook - The fetched wallet book.\n * @returns Tagged `walletConnect` options paired with their wallet option keys.\n * @not-instrumented\n */\nexport const buildWalletConnectOptions = ({\n  walletBook,\n}: BuildWalletConnectOptionsParams): ConnectionOptionForWalletOption[] => {\n  const result: ConnectionOptionForWalletOption[] = [];\n\n  for (const [walletKey, wallet] of Object.entries(walletBook.wallets)) {\n    if (shouldFilterWalletForWalletConnect({ wallet, walletKey })) {\n      continue;\n    }\n\n    if (!hasUsableDeeplink({ wallet })) {\n      continue;\n    }\n\n    const walletOptionKey = resolveWalletBookWalletOptionKey({\n      wallet,\n      walletKey,\n    });\n\n    // MetaMask is steered to the MetaMask SDK URI builder.\n    if (walletOptionKey === 'metamask') {\n      continue;\n    }\n\n    const chains = getChainsFromWalletSchema({ wallet, walletKey }).filter(\n      (chain) => WALLETCONNECT_SUPPORTED_CHAINS.has(chain)\n    );\n\n    for (const chain of chains) {\n      result.push({\n        option: {\n          chain,\n          deeplinks: {\n            native: wallet.mobile?.native,\n            universal: wallet.mobile?.universal,\n          },\n          type: 'walletConnect',\n        },\n        walletOptionKey,\n      });\n    }\n  }\n\n  return result;\n};\n","import { getSpriteUrl } from '../../legacyWalletBook/getSpriteUrl/getSpriteUrl';\nimport type { WalletBookSchema } from '../../legacyWalletBook/legacyWalletBook.types';\nimport type { WithWalletProviderDisplayOverride } from '../buildWithWalletProviderOptions/buildWithWalletProviderOptions';\nimport type {\n  InstallationUrls,\n  WalletConnectionOption,\n  WalletOption,\n} from '../walletOptionsCatalogue.types';\n\ntype BuildWalletOptionParams = {\n  connectionOptions: WalletConnectionOption[];\n  displayOverride?: WithWalletProviderDisplayOverride;\n  installationUrls?: InstallationUrls;\n  walletBook: WalletBookSchema;\n  walletOptionKey: string;\n};\n\n/**\n * Assembles a `WalletOption` for a resolved wallet option key, populated\n * with the connection options the transformers produced for it plus an\n * optional install / download URL bag.\n *\n * Display merge rules (provider self-announced metadata wins where set):\n *\n * - `name`: `displayOverride.name` ?? wallet book group name ?? wallet\n *   book wallet name ?? bare key.\n * - `iconUrl`: `displayOverride.iconUrl` ?? wallet book group sprite URL\n *   ?? wallet book wallet sprite URL ?? `''`.\n * - `primaryColor`: wallet book group brand color ?? wallet book wallet\n *   brand color (providers do not ship a primary color in their\n *   announcement metadata).\n * - `installationUrls`: copied through if present.\n *\n * The per-wallet fallback handles wallets that exist as individual entries\n * in the book (e.g. Rainbow) rather than as members of a multi-wallet group\n * — those don't get a `walletBook.groups[…]` shell.\n *\n * Why provider precedence: a registered wallet provider knows its own\n * brand best (EIP-6963 / Wallet Standard / vendor SDK announcement is the\n * wallet authoring its own identity). The wallet book fills in fields the\n * announcement does not carry — currently only `primaryColor`.\n *\n * @param params.connectionOptions - The connections to attach to this wallet option.\n * @param [params.displayOverride] - Provider-announced display info that overrides the wallet book's name and iconUrl.\n * @param [params.installationUrls] - Install/download URL bag for this wallet.\n * @param params.walletBook - The fetched wallet book.\n * @param params.walletOptionKey - The wallet option key.\n * @returns The constructed wallet option.\n * @not-instrumented\n */\nexport const buildWalletOption = ({\n  connectionOptions,\n  displayOverride,\n  installationUrls,\n  walletBook,\n  walletOptionKey,\n}: BuildWalletOptionParams): WalletOption => {\n  const group = walletBook.groups[walletOptionKey];\n  const groupSpriteId = group?.brand?.spriteId;\n  const groupIconUrl = groupSpriteId\n    ? getSpriteUrl({ spriteId: groupSpriteId })\n    : undefined;\n\n  // Fall back to the wallet entry's own brand when the wallet option key\n  // matches an individual wallet (e.g. Rainbow) rather than a multi-wallet\n  // group — those entries don't get a `walletBook.groups[…]` shell, so\n  // `group.brand` is undefined and we'd otherwise emit an empty iconUrl.\n  const walletEntry = walletBook.wallets[walletOptionKey];\n  const walletSpriteId = walletEntry?.brand?.spriteId;\n  const walletIconUrl = walletSpriteId\n    ? getSpriteUrl({ spriteId: walletSpriteId })\n    : undefined;\n\n  return {\n    connectionOptions,\n    iconUrl:\n      displayOverride?.iconUrl ?? groupIconUrl ?? walletIconUrl ?? '',\n    installationUrls,\n    key: walletOptionKey,\n    name:\n      displayOverride?.name ?? group?.name ?? walletEntry?.name ?? walletOptionKey,\n    primaryColor:\n      group?.brand?.primaryColor ?? walletEntry?.brand?.primaryColor,\n  };\n};\n","import type { WalletProvider } from '../walletProvider';\n\ntype HasWalletProviderConnectMethodParams = {\n  walletProvider: WalletProvider;\n};\n\n/**\n * Returns true when the given wallet provider exposes a `connect` method,\n * which is the signal we use to decide whether it belongs in the external\n * wallet picker as an `available provider`.\n *\n * Providers that don't expose `connect` (embedded wallets,\n * account-abstraction wrappers, MetaMask SDK / WalletConnect-backed\n * providers) are still sign-in capable, but via different SDK entry\n * points — they should not appear in the external picker as a\n * `withWalletProvider`-style option.\n *\n * Centralizing the predicate means future tweaks (e.g. a registry of\n * provider keys to exclude) land in one place and every consumer stays\n * in lockstep.\n *\n * @param params.walletProvider - The wallet provider to test.\n * @returns True when the provider exposes a `connect` method.\n * @not-instrumented\n */\nexport const hasWalletProviderConnectMethod = ({\n  walletProvider,\n}: HasWalletProviderConnectMethodParams): boolean =>\n  Boolean(walletProvider.connect);\n","import { WalletProviderPriority } from '../../wallets/walletProviderRegistry';\nimport type { WalletProviderRegistryEntry } from '../../wallets/walletProviderRegistry';\nimport type { WithWalletProviderSource } from '../walletOptionsCatalogue.types';\n\ntype ClassifyWithWalletProviderSourceParams = {\n  entry: WalletProviderRegistryEntry;\n};\n\n\n/**\n * Maps a registered wallet provider's registration priority to the\n * `WithWalletProviderSource` value that should appear on its catalogue option.\n *\n * Priority mapping (set by each chain extension when it calls\n * `registry.register`):\n *\n * - `WALLET_SDK` → `'sdk'` — branded SDKs wrapped by chain extensions\n *   (Base Account via `@base-org/account`, MetaMask Connect, …).\n * - `WALLET_SELF_ANNOUNCEMENT_STANDARD` → `'selfAnnounced'` — in-page\n *   self-announcement standards (EIP-6963 on EVM, Wallet Standard on\n *   Solana / Sui / …).\n * - `WINDOW_INJECT` → `'windowInjected'` — legacy `window.*` injection.\n *\n * Returns `undefined` for providers whose registration priority does not\n * correspond to a connectable external-wallet source — callers filter these\n * out before emitting catalogue options.\n *\n * @param params.entry - The registry entry to classify.\n * @returns The matching source, or `undefined` if this entry should not\n *   surface a `withWalletProvider` option.\n * @not-instrumented\n */\nexport const classifyWithWalletProviderSource = ({\n  entry,\n}: ClassifyWithWalletProviderSourceParams):\n  | WithWalletProviderSource\n  | undefined => {\n  const { priority } = entry;\n\n  if (priority === WalletProviderPriority.WALLET_SDK) {\n    return 'sdk';\n  }\n\n  if (priority === WalletProviderPriority.WALLET_SELF_ANNOUNCEMENT_STANDARD) {\n    return 'selfAnnounced';\n  }\n\n  if (priority === WalletProviderPriority.WINDOW_INJECT) {\n    return 'windowInjected';\n  }\n\n  return undefined;\n};\n","import type { Chain } from '../../../chain';\n\ntype StripChainSuffixParams = {\n  chain: Chain;\n  normalizedName: string;\n};\n\n/**\n * Removes the lowercased chain suffix that `normalizeWalletNameWithChain`\n * appends. Used by `findWalletOptionKeyForProviderKey` to recover the wallet\n * book wallet key candidate from a `walletProviderKey`. If the suffix is\n * not present (some chain extensions already bake the chain into the\n * display name), the input is returned unchanged.\n *\n * @param params.chain - The chain whose suffix should be stripped.\n * @param params.normalizedName - The normalized wallet-name-with-chain string.\n * @returns The name with the chain suffix removed, or the input unchanged.\n * @not-instrumented\n */\nexport const stripChainSuffix = ({\n  chain,\n  normalizedName,\n}: StripChainSuffixParams): string => {\n  const suffix = chain.toLowerCase();\n\n  if (normalizedName.endsWith(suffix)) {\n    return normalizedName.slice(0, -suffix.length);\n  }\n\n  return normalizedName;\n};\n","/**\n * Normalizes a wallet's self-announced `displayName` into a stable wallet\n * option key. Used by `findWalletOptionKeyForProviderKey` as the off-book\n * fallback — registered providers whose `walletProviderKey` does not\n * resolve to any wallet book entry still surface in the catalogue under a\n * key derived from the name they ship in their metadata.\n *\n * The normalization (lowercase + whitespace-strip) intentionally matches\n * how the legacy wallet book composes its `wallets.<key>` keys, so a\n * self-described provider's option will merge cleanly with its book entry\n * if one ever lands later.\n *\n * Multi-chain registrations of the same wallet (e.g. Phantom announced via\n * EIP-6963 on EVM and via Wallet Standard on Solana) collapse onto the\n * same wallet option through this normalization, since each registration\n * announces the same `displayName`.\n *\n * @param displayName - The provider's `metadata.displayName`.\n * @returns The normalized wallet option key (lowercased, no whitespace).\n * @not-instrumented\n */\nexport const normalizeWalletDisplayName = (displayName: string): string =>\n  displayName.toLowerCase().replace(/\\s+/g, '');\n","import type { WalletBookSchema } from '../../../legacyWalletBook/legacyWalletBook.types';\n\ntype FindByNameMatchParams = {\n  candidate: string;\n  walletBook: WalletBookSchema;\n};\n\nconst normalize = (value: string | undefined): string | undefined =>\n  value === undefined ? undefined : value.toLowerCase().replace(/\\s+/g, '');\n\n/**\n * Looks for a wallet book entry whose `name` or `shortName` normalizes to\n * the same string as `candidate`. Used as a fallback by\n * `findWalletOptionKeyForProviderKey` for providers whose\n * `walletProviderKey` strips down to a value that does not match any\n * `walletBook.wallets` key directly (e.g. an extension whose display name\n * happens to match the wallet's `shortName` instead of its book key).\n *\n * @param params.candidate - The lowercased, chain-suffix-stripped candidate.\n * @param params.walletBook - The fetched wallet book.\n * @returns The matching wallet book wallet key, or `undefined`.\n * @not-instrumented\n */\nexport const findByNameMatch = ({\n  candidate,\n  walletBook,\n}: FindByNameMatchParams): string | undefined => {\n  for (const [walletKey, wallet] of Object.entries(walletBook.wallets)) {\n    if (\n      normalize(wallet.name) === candidate ||\n      normalize(wallet.shortName) === candidate\n    ) {\n      return walletKey;\n    }\n  }\n\n  return undefined;\n};\n","import type { WalletBookSchema } from '../../../legacyWalletBook/legacyWalletBook.types';\n\ntype ResolveWalletOptionKeyParams = {\n  fallback: string;\n  wallet: WalletBookSchema['wallets'][string];\n};\n\n/**\n * Picks the wallet option (group) key for a wallet book wallet. The wallet\n * book carries the group association under a few different field names\n * (`group`, `chainGroup`, `walletGroup`) depending on the wallet's\n * provenance — this helper centralises the lookup. When none of those\n * fields are set, the wallet key itself acts as its own wallet option key.\n *\n * @param params.fallback - Wallet key to return if no group field is set.\n * @param params.wallet - The wallet book wallet entry.\n * @returns The resolved wallet option key.\n * @not-instrumented\n */\nexport const resolveWalletOptionKey = ({\n  fallback,\n  wallet,\n}: ResolveWalletOptionKeyParams): string =>\n  wallet.group ?? wallet.chainGroup ?? wallet.walletGroup ?? fallback;\n","import type { Chain } from '../../chain';\nimport type { WalletBookSchema } from '../../legacyWalletBook/legacyWalletBook.types';\nimport { splitWalletProviderKey } from '../../wallets/walletProvider/splitWalletProviderKey/splitWalletProviderKey';\nimport { stripChainSuffix } from '../../wallets/utils/stripChainSuffix/stripChainSuffix';\nimport type { WalletProvider } from '../../wallets/walletProvider/walletProvider.types';\nimport { normalizeWalletDisplayName } from '../normalizeWalletDisplayName/normalizeWalletDisplayName';\nimport { findByNameMatch } from './findByNameMatch/findByNameMatch';\nimport { resolveWalletOptionKey } from './resolveWalletOptionKey/resolveWalletOptionKey';\n\ntype FindWalletOptionKeyForProviderKeyParams = {\n  chain: Chain;\n  walletBook: WalletBookSchema;\n  walletProvider: WalletProvider;\n};\n\n/**\n * Resolves a registered wallet provider to the wallet option key it should\n * be bucketed under. Always returns a key — providers with no wallet book\n * match fall back to their self-announced `metadata.displayName`, so the\n * catalogue surfaces them as self-described tiles instead of silently\n * dropping them.\n *\n * Resolution order (each step short-circuits on first hit):\n *\n * 1. **Direct wallet book lookup with chain suffix** — try\n *    `walletBook.wallets[normalizedWalletNameWithChain]` as-is. Wallet\n *    book entries are inconsistent about whether they keep the chain\n *    suffix (e.g. `metamaskevm`) or strip it (e.g. `metamask`), so try\n *    the suffixed form first.\n * 2. **Direct wallet book lookup without chain suffix** — strip the\n *    suffix and retry.\n * 3. **Name match heuristic with chain suffix** — scan\n *    `walletBook.wallets` for an entry whose normalized `name` or\n *    `shortName` equals the suffixed candidate.\n * 4. **Name match heuristic without chain suffix** — same scan on the\n *    stripped candidate.\n * 5. **Display-name fallback** — derive a stable key from\n *    `walletProvider.metadata.displayName` via\n *    {@link normalizeWalletDisplayName}. Multi-chain registrations of the\n *    same self-described wallet (e.g. Phantom on EVM and Solana) collapse\n *    onto the same tile because each announces the same display name.\n *\n * @param params.chain - The provider's chain (used to strip the suffix).\n * @param params.walletBook - The fetched wallet book.\n * @param params.walletProvider - The registered wallet provider.\n * @returns The wallet option key for this provider.\n * @not-instrumented\n */\nexport const findWalletOptionKeyForProviderKey = ({\n  chain,\n  walletBook,\n  walletProvider,\n}: FindWalletOptionKeyForProviderKeyParams): string => {\n  const { normalizedWalletNameWithChain } = splitWalletProviderKey(\n    walletProvider.key\n  );\n  const strippedCandidate = stripChainSuffix({\n    chain,\n    normalizedName: normalizedWalletNameWithChain,\n  });\n  const candidates = [normalizedWalletNameWithChain, strippedCandidate];\n\n  for (const candidate of candidates) {\n    const directHit = walletBook.wallets[candidate];\n\n    if (directHit) {\n      return resolveWalletOptionKey({\n        fallback: candidate,\n        wallet: directHit,\n      });\n    }\n  }\n\n  for (const candidate of candidates) {\n    const nameMatchKey = findByNameMatch({\n      candidate,\n      walletBook,\n    });\n\n    if (nameMatchKey) {\n      return resolveWalletOptionKey({\n        fallback: nameMatchKey,\n        wallet: walletBook.wallets[nameMatchKey],\n      });\n    }\n  }\n\n  return normalizeWalletDisplayName(walletProvider.metadata.displayName);\n};\n","import { getCore } from '../../../client/core/getCore';\nimport type { DynamicClient } from '../../../client/types/DynamicClient';\nimport type { WalletBookSchema } from '../../legacyWalletBook/legacyWalletBook.types';\nimport { hasWalletProviderConnectMethod } from '../../wallets/hasWalletProviderConnectMethod';\nimport type { WalletProviderRegistryEntry } from '../../wallets/walletProviderRegistry';\nimport { classifyWithWalletProviderSource } from '../classifyWithWalletProviderSource/classifyWithWalletProviderSource';\nimport { findWalletOptionKeyForProviderKey } from '../findWalletOptionKeyForProviderKey/findWalletOptionKeyForProviderKey';\nimport type { WithWalletProviderConnectionOption } from '../walletOptionsCatalogue.types';\n\n/**\n * Display override sourced from a registered wallet provider's announced\n * metadata (EIP-6963 / Wallet Standard / vendor SDK). The outer\n * transformer applies these on top of any wallet book group entry — the\n * provider knows its own brand best, so `name` + `iconUrl` here win\n * over the wallet book's values when both exist.\n */\nexport type WithWalletProviderDisplayOverride = {\n  iconUrl: string;\n  name: string;\n};\n\n/**\n * One `WithWalletProviderConnectionOption` paired with the wallet option\n * key it should be bucketed under, plus the provider's self-announced\n * display metadata. The outer transformer groups by `walletOptionKey` and\n * uses `displayOverride` to build the wallet option shell, with provider\n * precedence over the wallet book's display fields.\n */\nexport type WithWalletProviderOptionForWalletOption = {\n  displayOverride: WithWalletProviderDisplayOverride;\n  option: WithWalletProviderConnectionOption;\n  walletOptionKey: string;\n};\n\ntype BuildWithWalletProviderOptionsParams = {\n  entries: WalletProviderRegistryEntry[];\n  walletBook: WalletBookSchema;\n};\n\n/**\n * Converts each registered wallet provider entry into a\n * `WithWalletProviderConnectionOption` paired with its target wallet\n * option key and the provider's display override. Every classifiable\n * entry surfaces in the catalogue; the outer transformer uses the\n * carried `displayOverride` to override any wallet book branding for\n * that key (provider self-announcement wins over book).\n *\n * Entries whose registration priority is not recognised by\n * `classifyWithWalletProviderSource` are dropped from the catalogue and\n * an error is logged so Datadog surfaces the unknown registration path —\n * in production this should never happen, every chain extension is\n * expected to register with one of the documented priorities.\n *\n * @param params.entries - Snapshot of the registry's entries.\n * @param params.walletBook - The fetched wallet book.\n * @param client - The Dynamic client (used for logging unclassifiable entries).\n * @returns An array of tagged options, in input order.\n * @not-instrumented\n */\nexport const buildWithWalletProviderOptions = (\n  { entries, walletBook }: BuildWithWalletProviderOptionsParams,\n  client: DynamicClient\n): WithWalletProviderOptionForWalletOption[] => {\n  const result: WithWalletProviderOptionForWalletOption[] = [];\n\n  for (const entry of entries) {\n    if (!hasWalletProviderConnectMethod({ walletProvider: entry.walletProvider })) {\n      continue;\n    }\n\n    const source = classifyWithWalletProviderSource({ entry });\n\n    if (!source) {\n      getCore(client).logger.error(\n        'buildWithWalletProviderOptions: registered wallet provider has an unrecognised priority — unable to identify how this wallet was registered',\n        {\n          chain: entry.walletProvider.chain,\n          displayName: entry.walletProvider.metadata.displayName,\n          priority: entry.priority,\n          walletProviderKey: entry.walletProvider.key,\n          walletProviderType: entry.walletProvider.walletProviderType,\n        }\n      );\n      continue;\n    }\n\n    const walletOptionKey = findWalletOptionKeyForProviderKey({\n      chain: entry.walletProvider.chain,\n      walletBook,\n      walletProvider: entry.walletProvider,\n    });\n\n    result.push({\n      displayOverride: {\n        iconUrl: entry.walletProvider.metadata.icon,\n        name: entry.walletProvider.metadata.displayName,\n      },\n      option: {\n        chain: entry.walletProvider.chain,\n        source,\n        type: 'withWalletProvider',\n        walletProviderKey: entry.walletProvider.key,\n      },\n      walletOptionKey,\n    });\n  }\n\n  return result;\n};\n","/**\n * Wallet option keys `getWalletOptionsCatalogue` drops before returning.\n * Curated, product-level suppression.\n *\n * Example: Base Account SDK is the recommended entry point for\n * Coinbase-managed users, so the legacy Coinbase Wallet entries are\n * suppressed in favor of the SDK-backed `baseaccount` tile. Both the\n * wallet book group key (`coinbase`) and the normalized display-name\n * key (`coinbasewallet`) are listed so suppression holds regardless of\n * how the resolver lands on a key.\n *\n * Used in: `getWalletOptionsCatalogue`.\n */\nexport const EXCLUDED_WALLET_OPTION_KEYS: ReadonlySet<string> = new Set([\n  'coinbase',\n  'coinbasewallet',\n]);\n","import type { WithWalletProviderDisplayOverride } from '../buildWithWalletProviderOptions/buildWithWalletProviderOptions';\nimport type { WalletConnectionOption } from '../walletOptionsCatalogue.types';\n\n/**\n * A `connectionOption` tagged with the wallet option key it belongs under.\n * Transformer outputs produce these; the catalogue groups them by\n * `walletOptionKey` before building wallet option shells.\n *\n * `displayOverride` is set only by the `withWalletProvider` transformer,\n * carrying the provider's self-announced `name` + `iconUrl`. The shell\n * builder applies it on top of any wallet book entry — provider\n * metadata wins over book branding.\n */\nexport type ConnectionOptionForWalletOption = {\n  displayOverride?: WithWalletProviderDisplayOverride;\n  option: WalletConnectionOption;\n  walletOptionKey: string;\n};\n\n/**\n * Bucket of grouped options for a single wallet option key, plus the\n * first-seen display override (if any). Returned by\n * `groupOptionsByWalletOption` for the catalogue to feed into the shell\n * builder.\n */\nexport type GroupedWalletOption = {\n  connectionOptions: WalletConnectionOption[];\n  displayOverride?: WithWalletProviderDisplayOverride;\n};\n\ntype GroupOptionsByWalletOptionParams = {\n  options: ConnectionOptionForWalletOption[];\n};\n\n/**\n * Buckets tagged connection options by their wallet option key. Preserves\n * first-seen order so that the caller's choice of\n * `walletOptionOrdering: 'relevance'` naturally inherits the upstream input\n * order (wallet book order for walletConnect/inAppBrowser/installation,\n * registry order for withWalletProvider).\n *\n * Carries through the first-seen `displayOverride` per wallet option\n * key, so the shell builder can apply provider-announced metadata on\n * top of any wallet book entry.\n *\n * @param params.options - The tagged options to group.\n * @returns A map from wallet option key to its grouped option bucket,\n *   iterable in first-seen order.\n * @not-instrumented\n */\nexport const groupOptionsByWalletOption = ({\n  options,\n}: GroupOptionsByWalletOptionParams): Map<string, GroupedWalletOption> => {\n  const map = new Map<string, GroupedWalletOption>();\n\n  for (const { displayOverride, option, walletOptionKey } of options) {\n    const existing = map.get(walletOptionKey);\n\n    if (existing) {\n      existing.connectionOptions.push(option);\n      if (!existing.displayOverride && displayOverride) {\n        existing.displayOverride = displayOverride;\n      }\n    } else {\n      map.set(walletOptionKey, {\n        connectionOptions: [option],\n        displayOverride,\n      });\n    }\n  }\n\n  return map;\n};\n","import type { WalletConnectionOption } from '../walletOptionsCatalogue.types';\n\n/**\n * Numeric priority for each `WalletConnectionOption` type. Lower values rank\n * first. Used to sort each wallet option's `connectionOptions` array so the\n * best connection path lands at index 0. Has no bearing on how the outer\n * wallet-option list is ordered — that's controlled by\n * `WalletOptionOrdering`.\n *\n * `withWalletProvider > walletConnect / metamaskSdkUri > inAppBrowser`\n */\nconst CONNECTION_OPTION_PRIORITY: Record<WalletConnectionOption['type'], number> = {\n  inAppBrowser: 2,\n  metamaskSdkUri: 1,\n  walletConnect: 1,\n  withWalletProvider: 0,\n};\n\ntype GetConnectionOptionPriorityParams = {\n  option: WalletConnectionOption;\n};\n\n/**\n * Returns the numeric priority of a `WalletConnectionOption` for sorting.\n * Lower numbers rank first.\n *\n * @param params.option - The connection option to inspect.\n * @returns The numeric priority — lower is better.\n * @not-instrumented\n */\nexport const getConnectionOptionPriority = ({\n  option,\n}: GetConnectionOptionPriorityParams): number =>\n  CONNECTION_OPTION_PRIORITY[option.type];\n","import { getConnectionOptionPriority } from '../getConnectionOptionPriority/getConnectionOptionPriority';\nimport type { WalletConnectionOption } from '../walletOptionsCatalogue.types';\n\ntype SortConnectionOptionsParams = {\n  options: WalletConnectionOption[];\n};\n\n/**\n * Sorts a wallet option's `connectionOptions` so the most preferred option lands at\n * index 0. Primary sort is by option-type priority\n * (`withWalletProvider` > URI deeplink > `inAppBrowser`);\n * within a type, ties break alphabetically by `chain` for deterministic\n * output across calls.\n *\n * Returns a new array — the input is not mutated.\n *\n * @param params.options - The options to sort.\n * @returns A new array in priority order.\n * @not-instrumented\n */\nexport const sortConnectionOptions = ({\n  options,\n}: SortConnectionOptionsParams): WalletConnectionOption[] =>\n  [...options].sort((a, b) => {\n    const priorityDelta =\n      getConnectionOptionPriority({ option: a }) -\n      getConnectionOptionPriority({ option: b });\n\n    if (priorityDelta !== 0) {\n      return priorityDelta;\n    }\n\n    return a.chain.localeCompare(b.chain);\n  });\n","/**\n * Hand-curated list of wallet book group keys that should surface at the top\n * of catalogue listings. Lower index = higher priority. Anything not in this\n * list falls through to the secondary sort (alphabetical by name).\n *\n * Used by `sortWalletOptions` (relevance mode) and by the react-demo's\n * WalletConnect picker. Keep both in sync when adding entries.\n */\nexport const PRIORITY_WALLET_KEYS: readonly string[] = [\n  'metamask',\n  'coinbase',\n  'baseaccount',\n  'phantom',\n  'magiceden',\n  'trust',\n  'okxwallet',\n  'rainbow',\n  'argentx',\n  'backpack',\n  'xverse',\n  'onekey',\n  'solflare',\n  'braavos',\n  'brave',\n  'unisat',\n  'bitgetwallet',\n  'coin98',\n];\n","import { PRIORITY_WALLET_KEYS } from '../../legacyWalletBook/priorityWalletKeys/priorityWalletKeys';\nimport type { WalletOption } from '../walletOptionsCatalogue.types';\n\ntype GetPriorityIndexParams = {\n  walletOption: WalletOption;\n};\n\n/**\n * Returns the index of a wallet option in `PRIORITY_WALLET_KEYS`, or\n * `Number.POSITIVE_INFINITY` when the wallet is not in the hand-curated\n * priority list. Lower index = higher priority.\n *\n * @param params.walletOption - The wallet option to inspect.\n * @returns Numeric priority index — lower is better.\n * @not-instrumented\n */\nexport const getPriorityIndex = ({\n  walletOption,\n}: GetPriorityIndexParams): number => {\n  const index = PRIORITY_WALLET_KEYS.indexOf(walletOption.key);\n\n  return index === -1 ? Number.POSITIVE_INFINITY : index;\n};\n","import { getPriorityIndex } from '../getPriorityIndex/getPriorityIndex';\nimport type { WalletOption } from '../walletOptionsCatalogue.types';\n\ntype CompareByRelevanceParams = {\n  a: WalletOption;\n  b: WalletOption;\n};\n\n/**\n * Compares two wallet options for relevance ordering: priority-list index\n * first, then alphabetical-by-name as the tie-break. Suitable for passing\n * straight to `Array.prototype.sort`.\n *\n * @param params.a - First wallet option.\n * @param params.b - Second wallet option.\n * @returns Negative when `a` ranks first, positive when `b` ranks first.\n * @not-instrumented\n */\nexport const compareByRelevance = ({\n  a,\n  b,\n}: CompareByRelevanceParams): number => {\n  const aIndex = getPriorityIndex({ walletOption: a });\n  const bIndex = getPriorityIndex({ walletOption: b });\n\n  if (aIndex !== bIndex) {\n    return aIndex - bIndex;\n  }\n\n  return a.name.localeCompare(b.name, undefined, { sensitivity: 'base' });\n};\n","import type { WalletOption } from '../walletOptionsCatalogue.types';\n\ntype HasAnyConnectionOptionParams = {\n  walletOption: WalletOption;\n};\n\n/**\n * True when the wallet option has at least one connection — i.e. the user\n * can sign in right now. Install-only wallet options surface in the\n * catalogue too (they carry `installationUrls`) but have an empty\n * `connectionOptions` array; this predicate distinguishes them from\n * actually connectable wallets in the relevance sort.\n *\n * @param params.walletOption - The wallet option to inspect.\n * @returns True when `connectionOptions` is non-empty.\n * @not-instrumented\n */\nexport const hasAnyConnectionOption = ({\n  walletOption,\n}: HasAnyConnectionOptionParams): boolean =>\n  walletOption.connectionOptions.length > 0;\n","import type { WalletOption } from '../walletOptionsCatalogue.types';\n\ntype HasInstalledProviderParams = {\n  walletOption: WalletOption;\n};\n\n/**\n * True when the wallet option has a `withWalletProvider` connection — i.e.\n * the user already has the wallet available in the page (browser extension,\n * Wallet Standard announcement, window injection, or an SDK-backed provider\n * one of our chain extensions registered). `connectionOptions` is\n * pre-sorted, so a registered provider always sits at index 0 when present.\n *\n * @param params.walletOption - The wallet option to inspect.\n * @returns True when an installed provider is available.\n * @not-instrumented\n */\nexport const hasInstalledProvider = ({\n  walletOption,\n}: HasInstalledProviderParams): boolean =>\n  walletOption.connectionOptions[0]?.type === 'withWalletProvider';\n","import { compareByRelevance } from '../compareByRelevance/compareByRelevance';\nimport { hasAnyConnectionOption } from '../hasAnyConnectionOption/hasAnyConnectionOption';\nimport { hasInstalledProvider } from '../hasInstalledProvider/hasInstalledProvider';\nimport type {\n  WalletOption,\n  WalletOptionOrdering,\n} from '../walletOptionsCatalogue.types';\n\ntype SortWalletOptionsParams = {\n  ordering: WalletOptionOrdering;\n  walletOptions: WalletOption[];\n};\n\n/**\n * Sorts the outer wallet-option list. This is the only ordering controlled\n * by the customer; the inner `connectionOptions` array of each wallet\n * option is ordered separately by `sortConnectionOptions` using a fixed\n * option-type priority.\n *\n * - `'relevance'` (default): bucket wallet options into three tiers, in\n *   this order:\n *     1. **Installed provider** — user already has the wallet available\n *        (`withWalletProvider` at index 0).\n *     2. **Connectable** — has at least one connection (URI deeplink\n *        or `inAppBrowser`) but no installed provider.\n *     3. **Install-only** — no connection at all; only `installationUrls`.\n *   Within each tier, rank by the hand-curated {@link PRIORITY_WALLET_KEYS}\n *   list (MetaMask, Coinbase, Phantom, …); unknown wallets fall through to\n *   alphabetical-by-name order at the tail of their tier.\n * - `'alphabetical'`: case-insensitive sort by wallet option `name`,\n *   without bucketing.\n *\n * Returns a new array — the input is not mutated.\n *\n * @param params.walletOptions - The wallet options to sort.\n * @param params.ordering - The requested ordering.\n * @returns A new array in the requested order.\n * @not-instrumented\n */\nexport const sortWalletOptions = ({\n  walletOptions,\n  ordering,\n}: SortWalletOptionsParams): WalletOption[] => {\n  if (ordering === 'alphabetical') {\n    return [...walletOptions].sort((a, b) =>\n      a.name.localeCompare(b.name, undefined, { sensitivity: 'base' })\n    );\n  }\n\n  const installed: WalletOption[] = [];\n  const connectable: WalletOption[] = [];\n  const installOnly: WalletOption[] = [];\n\n  for (const walletOption of walletOptions) {\n    if (hasInstalledProvider({ walletOption })) {\n      installed.push(walletOption);\n    } else if (hasAnyConnectionOption({ walletOption })) {\n      connectable.push(walletOption);\n    } else {\n      installOnly.push(walletOption);\n    }\n  }\n\n  installed.sort((a, b) => compareByRelevance({ a, b }));\n  connectable.sort((a, b) => compareByRelevance({ a, b }));\n  installOnly.sort((a, b) => compareByRelevance({ a, b }));\n\n  return [...installed, ...connectable, ...installOnly];\n};\n","import { getDefaultClient } from '../../../client/defaultClient';\nimport { fetchLegacyWalletBook } from '../../legacyWalletBook/fetchLegacyWalletBook';\nimport type { WalletBookSchema } from '../../legacyWalletBook/legacyWalletBook.types';\nimport { getWalletProviderRegistry } from '../../wallets/walletProviderRegistry';\nimport { buildInAppBrowserOptions } from '../buildInAppBrowserOptions/buildInAppBrowserOptions';\nimport { buildInstallationUrlsByWalletOptionKey } from '../buildInstallationUrlsByWalletOptionKey/buildInstallationUrlsByWalletOptionKey';\nimport { buildMetaMaskSdkUriOptions } from '../buildMetaMaskSdkUriOptions/buildMetaMaskSdkUriOptions';\nimport { buildWalletConnectOptions } from '../buildWalletConnectOptions/buildWalletConnectOptions';\nimport { buildWalletOption } from '../buildWalletOption/buildWalletOption';\nimport { buildWithWalletProviderOptions } from '../buildWithWalletProviderOptions/buildWithWalletProviderOptions';\nimport { EXCLUDED_WALLET_OPTION_KEYS } from '../excludedWalletOptionKeys/excludedWalletOptionKeys';\nimport { groupOptionsByWalletOption } from '../groupOptionsByWalletOption/groupOptionsByWalletOption';\nimport type { ConnectionOptionForWalletOption } from '../groupOptionsByWalletOption/groupOptionsByWalletOption';\nimport { sortConnectionOptions } from '../sortConnectionOptions/sortConnectionOptions';\nimport { sortWalletOptions } from '../sortWalletOptions/sortWalletOptions';\nimport type {\n  GetWalletOptionsCatalogueParams,\n  InstallationUrls,\n  WalletOption,\n  WalletOptionsCatalogue,\n} from '../walletOptionsCatalogue.types';\n\nconst EMPTY_WALLET_BOOK: WalletBookSchema = { groups: {}, wallets: {} };\n\n/**\n * Returns the catalogue of external wallet options a user can sign in\n * with through this client. Always includes installed wallet providers;\n * pass `includeMobileOptions: true` to additionally surface\n * WalletConnect, in-app-browser, and install links.\n *\n * Pass `excludedConnectionOptionTypes` to drop specific connection types\n * from the catalogue (e.g. `['inAppBrowser']` on desktop). Wallets whose\n * only connection was an excluded type fall through to the install-only\n * tier of the relevance ordering.\n *\n * @param [params] - Inclusion flag + ordering preference + exclusions.\n * @param [client] - The Dynamic client instance. Only required when using multiple Dynamic clients.\n * @returns A promise that resolves to the wallet options catalogue.\n * @not-instrumented\n */\nexport const getWalletOptionsCatalogue = async (\n  params: GetWalletOptionsCatalogueParams = {},\n  client = getDefaultClient()\n): Promise<WalletOptionsCatalogue> => {\n  const includeMobileOptions = params.includeMobileOptions ?? false;\n  const walletOptionOrdering = params.walletOptionOrdering ?? 'relevance';\n  const excludedConnectionOptionTypes = new Set(\n    params.excludedConnectionOptionTypes ?? []\n  );\n\n  const walletBook = includeMobileOptions\n    ? await fetchLegacyWalletBook(client)\n    : EMPTY_WALLET_BOOK;\n\n  const allConnectionOptions: ConnectionOptionForWalletOption[] = [];\n\n  if (!excludedConnectionOptionTypes.has('withWalletProvider')) {\n    const entries = getWalletProviderRegistry(client).listProviderEntries();\n    allConnectionOptions.push(\n      ...buildWithWalletProviderOptions({ entries, walletBook }, client)\n    );\n  }\n\n  if (includeMobileOptions) {\n    // Each URI-deeplink discriminator has its own builder with its own\n    // eligibility filter (WC requires `sign_v2`; MM SDK URI does not).\n    // Keeping them separate means excluding one discriminator never\n    // accidentally gates the other.\n    if (!excludedConnectionOptionTypes.has('walletConnect')) {\n      allConnectionOptions.push(...buildWalletConnectOptions({ walletBook }));\n    }\n    if (!excludedConnectionOptionTypes.has('metamaskSdkUri')) {\n      allConnectionOptions.push(...buildMetaMaskSdkUriOptions({ walletBook }));\n    }\n    if (!excludedConnectionOptionTypes.has('inAppBrowser')) {\n      allConnectionOptions.push(...buildInAppBrowserOptions({ walletBook }));\n    }\n  }\n\n  const installationUrlsByKey: Map<string, InstallationUrls> =\n    includeMobileOptions\n      ? buildInstallationUrlsByWalletOptionKey({ walletBook })\n      : new Map();\n\n  const grouped = groupOptionsByWalletOption({\n    options: allConnectionOptions,\n  });\n  // Union keeps connection-bearing entries first (in their first-seen order)\n  // and appends install-only entries — wallets the user can install but\n  // cannot connect to yet via any other channel.\n  const allWalletOptionKeys = new Set([\n    ...grouped.keys(),\n    ...installationUrlsByKey.keys(),\n  ]);\n  const walletOptions: WalletOption[] = [];\n\n  for (const walletOptionKey of allWalletOptionKeys) {\n    if (EXCLUDED_WALLET_OPTION_KEYS.has(walletOptionKey)) {\n      continue;\n    }\n\n    const groupedEntry = grouped.get(walletOptionKey);\n    const connectionOptions = groupedEntry\n      ? sortConnectionOptions({ options: groupedEntry.connectionOptions })\n      : [];\n\n    walletOptions.push(\n      buildWalletOption({\n        connectionOptions,\n        displayOverride: groupedEntry?.displayOverride,\n        installationUrls: installationUrlsByKey.get(walletOptionKey),\n        walletBook,\n        walletOptionKey,\n      })\n    );\n  }\n\n  return sortWalletOptions({ ordering: walletOptionOrdering, walletOptions });\n};\n","import { getCore } from '../../../client/core/getCore';\nimport { getDefaultClient } from '../../../client/defaultClient';\nimport { createApiClient } from '../../apiClient';\nimport { updateAuthFromVerifyResponse } from '../../auth/updateAuthFromVerifyResponse';\nimport type { OTPVerification } from '../../otp/otp.types';\nimport type { UpdateUserFields } from '../user.types';\n\ntype UpdateUserParams = {\n  userFields: UpdateUserFields;\n};\n\n/**\n * Updates the current user's profile information.\n *\n * This function allows updating various user fields such as email, name,\n * and other profile information. Some updates may require OTP verification,\n * like email and phone number.\n *\n * @param params.userFields - The user fields to update.\n * @param [client] - The Dynamic client instance. Only required when using multiple Dynamic clients.\n * @returns A promise that resolves to OTP verification details if verification is required, or undefined.\n  * @instrumented\n  * @redact-params\n */\nexport const updateUser = async (\n  { userFields }: UpdateUserParams,\n  client = getDefaultClient()\n): Promise<OTPVerification | undefined> => {\n  const core = getCore(client);\n  const apiClient = createApiClient({ includeMfaToken: true }, client);\n\n  const response = await apiClient.updateSelf({\n    environmentId: core.environmentId,\n    userFields,\n  });\n\n  updateAuthFromVerifyResponse({ response }, client);\n\n  if (response.emailVerification) {\n    return {\n      email: response.emailVerification.email,\n      verificationUUID: response.emailVerification.verificationUUID,\n    };\n  }\n\n  if (response.smsVerification) {\n    return {\n      isoCountryCode: response.smsVerification.isoCountryCode,\n      phoneCountryCode: response.smsVerification.phoneCountryCode,\n      phoneNumber: response.smsVerification.phoneNumber,\n      verificationUUID: response.smsVerification.verificationUUID,\n    };\n  }\n\n  return undefined;\n};\n","import { MfaBackupCodeAcknowledgement } from '@dynamic-labs/sdk-api-core';\n\nimport { getDefaultClient } from '../../../client/defaultClient';\nimport { updateUser } from '../../user/updateUser';\n\n/**\n * Acknowledges that the user has viewed and saved their MFA recovery codes.\n *\n * This function marks the recovery codes as acknowledged, indicating that\n * the user has properly backed up their MFA recovery codes for account recovery.\n *\n * @param [client] - The Dynamic client instance. Only required when using multiple Dynamic clients.\n * @returns A promise that resolves when the acknowledgment is complete.\n  * @instrumented\n */\nexport const acknowledgeRecoveryCodes = async (client = getDefaultClient()) => {\n  return updateUser(\n    {\n      userFields: {\n        mfaBackupCodeAcknowledgement: MfaBackupCodeAcknowledgement.Complete,\n      },\n    },\n    client\n  );\n};\n","import type { CreateMfaToken, TokenScope } from '@dynamic-labs/sdk-api-core';\n\nimport { getCore } from '../../../client/core/getCore';\nimport { getDefaultClient } from '../../../client/defaultClient';\nimport { createApiClient } from '../../apiClient';\nimport { updateAuthFromVerifyResponse } from '../../auth/updateAuthFromVerifyResponse';\nimport { emitEvent } from '../../clientEvents';\n\ntype AuthenticateMfaRecoveryCodeParams = {\n  code: string;\n  /** @deprecated Use `requestedScopes` instead. */\n  createMfaTokenOptions?: CreateMfaToken;\n  requestedScopes?: TokenScope[];\n};\n\n/**\n * Authenticates using an MFA recovery code.\n *\n * This function allows users to bypass normal MFA requirements by using\n * one of their backup recovery codes when none of the registered MFA methods are available.\n *\n * @param params.code - The recovery code to authenticate with.\n * @param [params.createMfaTokenOptions] - **Deprecated**: use `requestedScopes` instead. Optional configuration for MFA token creation.\n * @param [params.requestedScopes] - Optional scopes to request an elevated access token instead of an MFA token.\n * @param [client] - The Dynamic client instance. Only required when using multiple Dynamic clients.\n * @returns A promise that resolves to the MFA authentication response.\n * @not-instrumented\n */\nexport const authenticateMfaRecoveryCode = async (\n  { code, createMfaTokenOptions, requestedScopes }: AuthenticateMfaRecoveryCodeParams,\n  client = getDefaultClient()\n) => {\n  const core = getCore(client);\n  const apiClient = createApiClient({}, client);\n\n  try {\n    const response = await apiClient.authMfaRecovery({\n      environmentId: core.environmentId,\n      mFAAuthRecoveryDevicePostRequest: {\n        code,\n        createMfaToken: createMfaTokenOptions,\n        requestedScopes,\n      },\n    });\n\n    updateAuthFromVerifyResponse({ response }, client);\n\n    emitEvent(\n      {\n        args: { mfaToken: response.mfaToken },\n        event: 'mfaCompletionSuccess',\n      },\n      client\n    );\n\n    return response;\n  } catch (error) {\n    emitEvent(\n      {\n        args: { error },\n        event: 'mfaCompletionFailure',\n      },\n      client\n    );\n    throw error;\n  }\n};\n","import type { GetPasskeyAuthentica