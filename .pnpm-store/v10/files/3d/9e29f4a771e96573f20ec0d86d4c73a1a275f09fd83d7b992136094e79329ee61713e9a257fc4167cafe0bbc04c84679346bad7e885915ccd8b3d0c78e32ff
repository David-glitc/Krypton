o `{ isRequired: true }`\n * as a safety measure.\n *\n * @param params.scope - The scope to check (e.g., 'wallet:export').\n * @param [client] - The Dynamic client instance. Only required when using multiple Dynamic clients.\n * @returns The step-up check result with `isRequired`, `credentials`, and `defaultCredentialId`.\n *\n * @example\n * ```typescript\n * const result = await checkStepUpAuth({ scope: TokenScope.Walletexport });\n * if (result.isRequired) {\n *   // Show step-up auth UI using result.credentials\n * }\n * ```\n * @instrumented\n */\nexport const checkStepUpAuth = async (\n  { scope }: { scope: TokenScope },\n  client: DynamicClient = getDefaultClient()\n): Promise<StepUpCheckResponse> => {\n  // Fast local check: if we already have a valid elevated token, no step-up needed\n  const existingToken = getElevatedAccessToken(\n    { consume: false, scope },\n    client\n  );\n\n  if (existingToken) {\n    return { credentials: [], isRequired: false };\n  }\n\n  try {\n    const core = getCore(client);\n    const apiClient = createApiClient({}, client);\n\n    const response = await apiClient.stepUpCheck({\n      environmentId: core.environmentId,\n      stepUpCheckRequest: { scope },\n    });\n\n    return {\n      credentials: response.credentials ?? [],\n      defaultCredentialId: response.defaultCredentialId,\n      isRequired: response.isRequired,\n    };\n  } catch {\n    // Default to requiring step-up on any failure for safety\n    return STEP_UP_REQUIRED_DEFAULT;\n  }\n};\n","import { getCore } from '../../../../client/core/getCore';\nimport { getDefaultClient } from '../../../../client/defaultClient';\nimport { createApiClient } from '../../../apiClient';\nimport { parseElevatedAccessToken } from '../../updateAuthFromVerifyResponse/elevatedAccessTokens/parseElevatedAccessToken';\nimport { upsertElevatedAccessToken } from '../../updateAuthFromVerifyResponse/elevatedAccessTokens/upsertElevatedAccessToken';\n\ntype RequestExternalAuthElevatedTokenParams = {\n  externalJwt: string;\n};\n\n/**\n * Requests an elevated access token using an external auth assertion JWT.\n *\n * The assertion JWT must be signed by the customer's backend using the same key\n * registered in the environment's external auth JWKS URL. It must include\n * `sub`, `scope`, `jti`, and `exp` claims.\n *\n * The returned elevated access token is automatically parsed and stored in state,\n * and can be retrieved via `getElevatedAccessToken`.\n *\n * @param params.externalJwt - The assertion JWT signed by the customer's backend.\n * @param [client] - The Dynamic client instance. Only required when using multiple Dynamic clients.\n * @returns A promise that resolves to the assertion response containing the elevated access token.\n * @instrumented\n * @redact-params\n */\nexport const requestExternalAuthElevatedToken = async (\n  { externalJwt }: RequestExternalAuthElevatedTokenParams,\n  client = getDefaultClient()\n) => {\n  const core = getCore(client);\n  const apiClient = createApiClient({}, client);\n\n  const response = await apiClient.externalAuthVerify({\n    environmentId: core.environmentId,\n    externalAuthSigninRequest: {\n      jwt: externalJwt,\n    },\n  });\n\n  const parsedToken = parseElevatedAccessToken({\n    token: response.elevatedAccessToken,\n  });\n  if (parsedToken) {\n    const currentTokens = core.state.get().elevatedAccessTokens || [];\n    core.state.set({\n      elevatedAccessTokens: upsertElevatedAccessToken({\n        currentTokens,\n        newToken: parsedToken,\n      }),\n    });\n  }\n\n  return response;\n};\n","import { getCore } from '../../../../client/core/getCore';\nimport { getDefaultClient } from '../../../../client/defaultClient';\nimport { createApiClient } from '../../../apiClient';\nimport { updateAuthFromVerifyResponse } from '../../updateAuthFromVerifyResponse';\n\ntype SignInWithExternalJwtParams = {\n  externalJwt?: string;\n  sessionPublicKey?: string;\n};\n\n/**\n * Signs in a user using an external JWT token.\n *\n * This function allows authentication using JWT tokens from external providers,\n * enabling integration with custom authentication systems.\n *\n * @param [params.externalJwt] - Optional external JWT token to authenticate with. Not required when using cookie based auth.\n * @param [client] - The Dynamic client instance. Only required when using multiple Dynamic clients.\n * @returns A promise that resolves to the authentication response from the server.\n  * @instrumented\n  * @redact-params\n */\nexport const signInWithExternalJwt = async (\n  { externalJwt, sessionPublicKey }: SignInWithExternalJwtParams = {},\n  client = getDefaultClient()\n) => {\n  const core = getCore(client);\n  const apiClient = createApiClient({}, client);\n\n  const response = await apiClient.externalAuthSignin({\n    environmentId: core.environmentId,\n    externalAuthSigninRequest: {\n      jwt: externalJwt,\n      sessionPublicKey,\n    },\n  });\n\n  updateAuthFromVerifyResponse({ response }, client);\n\n  return response;\n};\n","import { getDefaultClient } from '../../../client/defaultClient';\nimport { logoutWithReason } from '../logoutWithReason';\n\n/**\n * Logs out the current user and clears all authentication data.\n *\n * @param [client] - The Dynamic client instance. Only required when using multiple Dynamic clients.\n * @returns A promise that resolves when the logout process is complete.\n * @not-instrumented\n */\nexport const logout = async (client = getDefaultClient()) => {\n  /**\n   * Delegates to `logoutWithReason` with `'user-intent'` so telemetry correctly\n   * attributes the logout to an explicit user action. Instrumentation lives on\n   * `logoutWithReason` — this wrapper is intentionally not instrumented so that\n   * Datadog sees a single function name per logout regardless of entry point.\n   */\n  return logoutWithReason({ reason: 'user-intent' }, client);\n};\n","import { TokenScope } from '@dynamic-labs/sdk-api-core';\n\ni